Sub RemoveRPM_Center_Slides1_14()

    Dim sld As Slide, shp As Shape, tbl As Table, i As Long
    
    For i = 1 To Application.Min(14, ActivePresentation.Slides.Count)
        For Each shp In ActivePresentation.Slides(i).Shapes
            
            If shp.HasTable Then
                Set tbl = shp.Table
                
                If tbl.Rows.Count >= 3 Then
                    With tbl.Cell(3, 1).Shape.TextFrame
                        .TextRange.Text = Replace(.TextRange.Text, "rpm", "", , , vbTextCompare)
                        .TextRange.ParagraphFormat.Alignment = ppAlignCenter
                        .VerticalAnchor = msoAnchorMiddle
                    End With
                End If
                
            End If
            
        Next shp
    Next i

End Sub
