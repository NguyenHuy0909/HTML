Function RemoveElement(arr As Variant, index As Long) As Variant

    Dim i As Long
    Dim n As Long
    Dim newArr() As Variant

    n = UBound(arr) - LBound(arr)

    ReDim newArr(LBound(arr) To UBound(arr) - 1)

    For i = LBound(arr) To UBound(arr)

        If i <> index Then
        
            If i < index Then
                newArr(i) = arr(i)
            Else
                newArr(i - 1) = arr(i)
            End If
            
        End If

    Next i

    RemoveElement = newArr

End Function
