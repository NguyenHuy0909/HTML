Function ReadGIDHeaderValues(ts As Object) As Object

    Dim dict As Object
    Dim line As String
    Dim key As String
    Dim value As String
    Dim parts As Variant

    Set dict = CreateObject("Scripting.Dictionary")

    Do Until ts.AtEndOfStream

        line = Trim(ts.ReadLine)

        If InStr(line, "END") > 0 Then Exit Do

        If InStr(line, "=") > 0 Then

            parts = Split(line, "=")

            key = Trim(parts(0))
            value = Trim(parts(1))

            value = Replace(value, "'", "")

            dict(key) = value

        End If

    Loop

    Set ReadGIDHeaderValues = dict

End Function
