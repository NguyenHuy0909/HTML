Sub ImportGID(filepath As String, ws_data As Worksheet, _
              first_row As Long, col_header As Long)

    Dim fso As Object
    Dim ts As Object
    Dim line As String
    
    Dim dataArr() As Variant
    Dim rowCount As Long
    Dim colCount As Long
    
    Dim i As Long
    Dim maxCol As Long

    Set fso = CreateObject("Scripting.FileSystemObject")
    Set ts = fso.OpenTextFile(filepath, 1)

    '--- Find END ---
    Do Until ts.AtEndOfStream
        line = ts.ReadLine
        If InStr(1, line, "END", vbBinaryCompare) > 0 Then Exit Do
    Loop

    '--- First pass: count rows & max columns ---
    Do Until ts.AtEndOfStream
    
        line = ts.ReadLine
        
        rowCount = rowCount + 1
        
        colCount = Len(line) \ 16
        
        If colCount > maxCol Then
            maxCol = colCount
        End If
        
    Loop

    ts.Close

    '--- Reopen file ---
    Set ts = fso.OpenTextFile(filepath, 1)

    '--- Find END again ---
    Do Until ts.AtEndOfStream
        line = ts.ReadLine
        If InStr(1, line, "END", vbBinaryCompare) > 0 Then Exit Do
    Loop

    ReDim dataArr(1 To rowCount, 1 To maxCol)

    '--- Read data ---
    rowCount = 0

    Do Until ts.AtEndOfStream

        line = ts.ReadLine
        rowCount = rowCount + 1
        
        For i = 1 To maxCol
        
            dataArr(rowCount, i) = Trim(Mid(line, (i - 1) * 16 + 1, 16))
            
        Next i

    Loop

    ts.Close

    '--- Write to Excel in one operation ---
    ws_data.Cells(first_row, col_header).Resize(UBound(dataArr, 1), _
                                                UBound(dataArr, 2)).Value = dataArr

End Sub
