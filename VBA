Private Sub Worksheet_SelectionChange(ByVal Target As Range)
    ' Xóa viền cũ
    Cells.Borders.LineStyle = xlNone
    
    ' Tô viền cho ô được chọn
    With Target.Borders(xlEdgeBottom)
        .LineStyle = xlContinuous
        .ColorIndex = 1 ' Màu đen
        .TintAndShade = 0
        .Weight = xlThin ' Độ dày của viền
    End With
    With Target.Borders(xlEdgeRight)
        .LineStyle = xlContinuous
        .ColorIndex = 1
        .TintAndShade = 0
        .Weight = xlThin
    End With
    With Target.Borders(xlEdgeLeft)
        .LineStyle = xlContinuous
        .ColorIndex = 1
        .TintAndShade = 0
        .Weight = xlThin
    End With
    With Target.Borders(xlEdgeTop)
        .LineStyle = xlContinuous
        .ColorIndex = 1
        .TintAndShade = 0
        .Weight = xlThin
    End With
    
    ' Highlight toàn bộ hàng và cột
    Target.EntireRow.Borders(xlEdgeBottom).LineStyle = xlContinuous
    Target.EntireColumn.Borders(xlEdgeRight).LineStyle = xlContinuous
End Sub
