Public Function GetArrayFromSheet(ByVal groupName As String) As Variant

    Dim ws As Worksheet
    Dim lastCol As Long
    Dim rng As Range, FCell As Range
    Dim tmpArr As Variant
    Dim result() As Variant
    Dim i As Long, n As Long

    Set ws = ThisWorkbook.Sheets("Config")

    Set FCell = FoundCellFromSheet(ws, groupName)
    If FCell Is Nothing Then Exit Function

    lastCol = ws.Cells(FCell.Row, ws.Columns.Count).End(xlToLeft).Column
    Set rng = ws.Range(ws.Cells(FCell.Row, 4), ws.Cells(FCell.Row, lastCol))

    tmpArr = rng.Value

    ' Nếu chỉ có 1 ô thì rng.Value không phải array
    If Not IsArray(tmpArr) Then
        If Len(Trim(tmpArr & "")) > 0 Then
            ReDim result(1 To 1)
            result(1) = tmpArr
            GetArrayFromSheet = result
        End If
        Exit Function
    End If

    For i = 1 To UBound(tmpArr, 2)
        If Len(Trim(tmpArr(1, i) & "")) > 0 Then
            n = n + 1
        End If
    Next i

    If n = 0 Then Exit Function

    ReDim result(1 To n)
    n = 0

    For i = 1 To UBound(tmpArr, 2)
        If Len(Trim(tmpArr(1, i) & "")) > 0 Then
            n = n + 1
            result(n) = tmpArr(1, i)
        End If
    Next i

    GetArrayFromSheet = result

End Function
