Function GetHeaderBlock(ts As Object, headerName As String) As String

    Dim line As String
    Dim buffer As String
    Dim started As Boolean
    
    buffer = ""
    started = False
    
    Do Until ts.AtEndOfStream
    
        line = ts.ReadLine
        
        If started = False Then
            If InStr(1, line, headerName, vbBinaryCompare) > 0 Then
                buffer = Trim(line)
                started = True
                
                'nếu dòng đầu không kết thúc bằng &, block kết thúc luôn
                If Right(Trim(line), 1) <> "&" Then Exit Do
            End If
        Else
            buffer = buffer & " " & Trim(line)
            
            'nếu dòng hiện tại không còn &, block kết thúc
            If Right(Trim(line), 1) <> "&" Then Exit Do
        End If
        
    Loop
    
    buffer = Replace(buffer, "&", "")
    
    GetHeaderBlock = buffer

End Function

Function HeaderBlockToArray(headerBlock As String) As Variant

    Dim parts As Variant
    Dim arr() As Variant
    Dim i As Long, n As Long, j As Long
    
    parts = Split(headerBlock, "'")
    
    'đếm số phần tử thật
    n = 0
    For i = LBound(parts) To UBound(parts)
        If i Mod 2 = 1 Then
            If Trim(parts(i)) <> "" Then n = n + 1
        End If
    Next i
    
    ReDim arr(1 To n)
    
    j = 1
    For i = LBound(parts) To UBound(parts)
        If i Mod 2 = 1 Then
            If Trim(parts(i)) <> "" Then
                arr(j) = Trim(parts(i))
                j = j + 1
            End If
        End If
    Next i
    
    HeaderBlockToArray = arr

End Function


Function GetHeaderArray(ts As Object, headerName As String) As Variant

    Dim headerBlock As String
    
    headerBlock = GetHeaderBlock(ts, headerName)
    GetHeaderArray = HeaderBlockToArray(headerBlock)

End Function
