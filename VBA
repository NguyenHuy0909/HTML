Private Sub UpdateAxisBlock( _
    ByVal Target As Range, _
    ByVal chartIndex As Variant, _
    ByVal axisCells As Variant)

    Dim ch As ChartObject
    Dim val As Double
    Dim i As Long
    
    Set ch = Me.ChartObjects("Chart " & chartIndex)
    
    With ch.Chart.Axes(xlValue)
        
        For i = 0 To 3
            
            If Not Intersect(Target, axisCells(i)) Is Nothing Then
                
                val = CDbl(axisCells(i).Value)
                
                Select Case i
                    Case 0: .MinimumScale = val
                    Case 1: .MaximumScale = val
                    Case 2: .MajorUnit = val
                    Case 3: .MinorUnit = val
                End Select
                
            End If
            
        Next i
        
    End With

End Sub
