                Dim para As TextRange
                Set para = tocBox.TextFrame.TextRange.Paragraphs(p)
                ' Select only from "ページ" to end of page number/range
                Dim linkLen As Long
                linkLen = Len(pText) - pwPos + 1
                ' Strip trailing CR if present
                If Right(Mid(pText, pwPos, linkLen), 1) = Chr(13) Then
                    linkLen = linkLen - 1
                End If
                Dim rng As TextRange
                Set rng = para.Characters(pwPos, linkLen)
                rng.ActionSettings(ppMouseClick).Hyperlink.SubAddress = _
                    pres.Slides(slideIdx).SlideID & "," & slideIdx & ","
