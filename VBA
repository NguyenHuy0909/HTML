Function GetGIDHeaderArray(filepath As String, headerName As String) As Variant

    Dim fso As Object
    Dim ts As Object
    Dim line As String
    Dim buffer As String
    Dim parts As Variant
    Dim arr() As Variant
    Dim i As Long, n As Long

    Set fso = CreateObject("Scripting.FileSystemObject")
    Set ts = fso.OpenTextFile(filepath, 1)

    Do Until ts.AtEndOfStream

        line = ts.ReadLine

        If InStr(1, line, headerName, vbBinaryCompare) > 0 Then
        
            buffer = line
            
            If Not ts.AtEndOfStream Then
                buffer = buffer & ts.ReadLine
            End If
            
            buffer = Replace(buffer, "&", "")
            Exit Do
            
        End If

    Loop

    ts.Close

    parts = Split(buffer, "'")

    n = UBound(parts) \ 2
    ReDim arr(1 To n)

    For i = 1 To n
        arr(i) = Trim(parts(2 * i))
    Next i

    GetGIDHeaderArray = arr

End Function
