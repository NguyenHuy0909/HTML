Function GetChannelIndex(channelArr As Variant, outputArr As Variant) As Variant

    Dim i As Long
    Dim j As Long
    Dim idx() As Long
    Dim n As Long

    ReDim idx(1 To UBound(outputArr) - LBound(outputArr) + 1)

    For j = LBound(outputArr) To UBound(outputArr)
    
        For i = LBound(channelArr) To UBound(channelArr)
        
            If channelArr(i) = outputArr(j) Then
            
                n = n + 1
                idx(n) = i
                Exit For
                
            End If
            
        Next i
        
    Next j

    ReDim Preserve idx(1 To n)

    GetChannelIndex = idx

End Function
