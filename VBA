Private Function GetHeaderShape(sld As Slide) As Shape
    Dim shp As Shape
    For Each shp In sld.Shapes
        If shp.Name = "header" Then
            If shp.HasTextFrame Then
                Set GetHeaderShape = shp
                Exit Function
            End If
        End If
    Next shp
End Function


For i = tocSlideIdx + 1 To pres.Slides.Count
    Dim hdrShape As Shape
    Set hdrShape = GetHeaderShape(pres.Slides(i))

    If hdrShape Is Nothing Then GoTo NextSlide

    hdr = Trim(hdrShape.TextFrame.TextRange.Text)

    With hdrShape.ActionSettings(ppMouseClick).Hyperlink
        .Address = ""
        .SubAddress = tocSlide.SlideID & "," & tocSlide.SlideIndex & "," & tocSlide.Name
    End With
