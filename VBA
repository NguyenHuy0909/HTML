Sub ReplaceIndirectWithDirectLink()

    Dim c As Range
    Dim rng As Range
    Dim addr As String
    
    Set rng = Selection
    
    Application.ScreenUpdating = False
    
    For Each c In rng
        If c.HasFormula Then
        
            If InStr(1, c.Formula, "INDIRECT", vbTextCompare) > 0 Then
            
                On Error Resume Next
                addr = c.DirectPrecedents.Address(External:=True)
                On Error GoTo 0
                
                If addr <> "" Then
                    c.Formula = "=" & addr
                End If
                
            End If
            
        End If
    Next c

    Application.ScreenUpdating = True

End Sub
