Function OpenGIDFile(filepath As String) As Object

    Dim fso As Object
    Dim ts As Object
    
    Set fso = CreateObject("Scripting.FileSystemObject")
    
    If fso.FileExists(filepath) Then
    
        Set ts = fso.OpenTextFile(filepath, 1)
        Set OpenGIDFile = ts
        
    Else
    
        Set OpenGIDFile = Nothing
        
    End If

End Function
