Sub ReadAllCSV()
    Dim folderPath As String
    Dim fileName As String
    
    folderPath = "D:\FolderA\"
    
    If Right(folderPath, 1) <> "\" Then
        folderPath = folderPath & "\"
    End If
    
    fileName = Dir(folderPath & "*.csv")
    
    Do While fileName <> ""
        Debug.Print fileName
        ' xử lý file ở đây
        
        fileName = Dir
    Loop
End Sub
