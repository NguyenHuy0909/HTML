Sub ConvertIndirectInSheet()

    Dim ws As Worksheet
    Dim c As Range
    Dim addr As String
    
    Set ws = ActiveSheet
    
    Application.ScreenUpdating = False
    
    For Each c In ws.UsedRange
    
        If c.HasFormula Then
        
            If InStr(1, c.Formula, "INDIRECT", vbTextCompare) > 0 Then
            
                On Error Resume Next
                addr = c.DirectPrecedents.Address(External:=True)
                On Error GoTo 0
                
                If addr <> "" Then
                    c.Formula = "=" & addr
                End If
                
            End If
            
        End If
        
    Next c
    
    Application.ScreenUpdating = True
    
    MsgBox "Done converting INDIRECT in sheet"

End Sub
