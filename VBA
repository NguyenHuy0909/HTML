Sub WriteSelectedHeader(ws As Worksheet, _
                        row_header As Long, _
                        col_header As Long, _
                        header_control As Variant, _
                        headerDict As Object)

    Dim i As Long
    Dim key As String

    For i = LBound(header_control) To UBound(header_control)

        key = header_control(i)

        ws.Cells(row_header + i, 1) = key

        If headerDict.Exists(key) Then
            ws.Cells(row_header + i, col_header) = headerDict(key)
        End If

    Next i

End Sub
