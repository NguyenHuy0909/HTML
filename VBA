Function RangeToArray1D(rng As Range) As Variant

    Dim data As Variant
    Dim result() As Variant
    Dim i As Long
    
    data = rng.Value

    If rng.Rows.Count > 1 Then
    
        ReDim result(1 To rng.Rows.Count)
        
        For i = 1 To rng.Rows.Count
            result(i) = data(i, 1)
        Next i
        
    Else
    
        ReDim result(1 To rng.Columns.Count)
        
        For i = 1 To rng.Columns.Count
            result(i) = data(1, i)
        Next i
        
    End If

    RangeToArray1D = result

End Function
