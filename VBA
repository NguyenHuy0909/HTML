Sub Numbering_All_Cells()

    Dim shp As Shape, tbl As Table
    Dim r As Long, c As Long
    Dim n As Long
    
    For Each shp In ActiveWindow.Selection.ShapeRange
        If shp.HasTable Then
            Set tbl = shp.Table
            
            n = 1
            For r = 3 To Application.Min(6, tbl.Rows.Count)
                For c = 3 To Application.Min(14, tbl.Columns.Count)
                    
                    tbl.Cell(r, c).Shape.TextFrame.TextRange.Text = n
                    n = n + 1
                    
                Next c
            Next r
            
        End If
    Next shp

End Sub
