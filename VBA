Sub Test_OneCell_DataBar()

    Dim ws As Worksheet
    Dim fc As FormatCondition
    
    Set ws = ActiveSheet
    
    'Xóa CF cũ của ô P3
    ws.Range("P3").FormatConditions.Delete
    
    'Tạo Data Bar mới cho đúng 1 ô
    Set fc = ws.Range("P3").FormatConditions.AddDatabar
    
    With fc
        .ShowValue = False
        
        .MinPoint.Modify newtype:=xlConditionValueFormula, newvalue:="=N3"
        .MaxPoint.Modify newtype:=xlConditionValueFormula, newvalue:="=O3"
        
        .BarColor.Color = RGB(0, 176, 240)
        
        On Error Resume Next
        .BarFillType = xlDataBarFillSolid
        .BarBorder.Type = xlDataBarBorderNone
        On Error GoTo 0
        
        .Direction = xlContext
    End With

End Sub
