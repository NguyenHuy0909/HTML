Sub Convert_ms()

    Dim c As Range
    Dim lastRow As Long
    Dim data_rng As Range
    
    Call initWS_data

    For Each c In ws_data.UsedRange
    
        If LCase(c.Value) = "acce" Then
        
            lastRow = ws_data.Cells(ws_data.Rows.Count, c.Column).End(xlUp).Row
            
            'data
            Set data_rng = ws_data.Range(c.Offset(1), ws_data.Cells(lastRow, c.Column))
            data_rng.Value = ws_data.Evaluate(data_rng.Address & "*0.001")
            
            'unit (hàng ngay dưới header)
            c.Offset(1).Replace "mm/s^2", "m/s^2", xlPart
            
        End If
        
    Next c

End Sub
