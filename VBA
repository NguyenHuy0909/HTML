Sub ImportGID(ByVal filepath As String, ByRef r As Long, ByRef c As Long, ByRef row_header As Long)

    Dim fso As Object, ts As Object
    Dim line As String
    Dim i As Long, col As Long, lineCount As Long, actived_line As Long

    Application.ScreenUpdating = False

    Set fso = CreateObject("Scripting.FileSystemObject")
    Set ts = fso.OpenTextFile(filepath, 1)

    lineCount = 0
    actived_line = 1000000000

    Do Until ts.AtEndOfStream

        line = ts.ReadLine
        lineCount = lineCount + 1

        If InStr(1, line, "END", vbBinaryCompare) > 0 Then
            actived_line = lineCount + 1
        End If

        If lineCount >= actived_line Then

            col = col_header

            Do While Len(line) > 0

                ws_data.Cells(row_header, col).Value = Left(line, 16)

                line = Mid(line, 17)

                col = col + 1

            Loop

            row_header = row_header + 1
            col = col_header

        End If

    Loop

    ts.Close

    Application.ScreenUpdating = True

End Sub
