Sub ImportGID(ByVal filepath As String, ByRef r As Long, ByRef c As Long, ByRef row_header As Long)

    Dim fso As Object, ts As Object
    Dim line As String
    Dim col As Long
    Dim i As Long

    Application.ScreenUpdating = False

    Set fso = CreateObject("Scripting.FileSystemObject")
    Set ts = fso.OpenTextFile(filepath, 1)

    'Find END
    Do Until ts.AtEndOfStream
        line = ts.ReadLine
        If InStr(1, line, "END", vbBinaryCompare) > 0 Then Exit Do
    Loop

    'Read data
    Do Until ts.AtEndOfStream

        line = ts.ReadLine
        col = col_header

        For i = 1 To Len(line) Step 16

            ws_data.Cells(row_header, col).Value = Trim(Mid(line, i, 16))

            col = col + 1

        Next i

        row_header = row_header + 1

    Loop

    ts.Close

    Application.ScreenUpdating = True

End Sub
