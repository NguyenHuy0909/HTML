near-gradient(#fafafa,#ececec);border-bottom:1px solid #c8c8c8;height:40px;flex-shrink:0}\n  .titlebar .brand{font-size:13px;font-weight:600;color:#1d4d80;padding:0 6px 0 2px;border-right:1px solid #d4d4d4;margin-right:2px;white-space:nowrap}\n  .titlebar-spacer{flex:1}\n  .titlebar .title-sep{width:1px;background:#c8c8c8;align-self:stretch;margin:4px 4px;flex-shrink:0}\n  .titlebar-tabs{padding:0;background:transparent;border-bottom:none;flex:0 1 auto;overflow-x:auto;overflow-y:hidden;max-width:50vw;align-self:flex-end}\n  .titlebar-tabs .tab{padding:5px 12px 6px;font-size:11px;background:#e8e8e8;border-bottom:1px solid #c8c8c8;border-radius:3px 3px 0 0;white-space:nowrap;line-height:1.3}\n  .titlebar-tabs .tab.active{background:#fff;border-bottom-color:#fff}\n\n  /* Excel-ribbon (4 groups: Layout / View / Analysis / Scale) */\n  .ribbon{display:flex;flex-wrap:nowrap;gap:0;align-items:stretch;padding:4px 4px 0;background:linear-gradient(#fafafa,#eef1f5);border-bottom:1px solid #c8c8c8;overflow-x:auto}\n  .ribbon .ctrl-group{display:flex;flex-direction:column;gap:3px;padding:4px 10px 16px;border-right:1px solid #d4d4d4;position:relative;background:transparent;flex:0 0 auto}\n  .ribbon .ctrl-group:last-of-type{border-right:1px solid #d4d4d4}\n  .ribbon .ctrl-group[data-grp=\"layout\"]  {min-width:160px}\n  .ribbon .ctrl-group[data-grp=\"view\"]    {min-width:110px}\n  .ribbon .ctrl-group[data-grp=\"analysis\"]{min-width:200px}\n  .ribbon .ctrl-group[data-grp=\"scale\"]   {min-width:200px}\n  .ribbon .layout-grid{display:grid;grid-template-columns:auto 60px 28px;gap:3px 6px;align-items:center;font-size:11px}\n  .ribbon .layout-grid .ctrl-lbl{justify-self:end}\n  .ribbon .grp-label{position:absolute;left:0;right:0;bottom:1px;text-align:center;font-size:10px;color:#666;letter-spacing:.02em;pointer-events:none}\n  .ribbon .ctrl-row{display:flex;gap:10px;align-items:center;font-size:11px;flex-wrap:wrap}\n  .ribbon .ctrl-row label{display:inline-flex;align-items:center;gap:4px;cursor:pointer}\n  .ribbon .ctrl-lbl{font-size:11px;color:#4a4a4a}\n  .ribbon .ctrl-divider{height:1px;background:#d8d8d8;margin:3px 0}\n  .ribbon-spacer{flex:1}\n  .ribbon .scale-grid{display:grid;grid-template-columns:auto repeat(3,54px);gap:3px;align-items:center;font-size:10px}\n  .icon-btn{min-width:36px;height:30px;padding:0 8px;border:1px solid #c8c8c8;background:#fff;cursor:pointer;font-size:13px;border-radius:2px;display:inline-flex;align-items:center;justify-content:center;gap:4px;font-family:inherit}\n  .icon-btn .ico{font-size:15px}\n  .icon-btn .lbl{font-size:11px;color:#333}\n  .icon-btn:hover{background:#eef4fb;border-color:#5b9dd9}\n  .btn.btn-sm{padding:2px 8px;font-size:11px;height:30px;line-height:1;display:inline-flex;align-items:center;gap:5px}\n  .btn.btn-sm .ico{font-size:14px}\n\n  /* status bar */\n  .status{position:fixed;bottom:0;left:0;right:0;background:linear-gradient(#ececec,#d8d8d8);border-top:1px solid #c8c8c8;padding:2px 10px;font-size:11px;color:#4a4a4a;display:flex;gap:14px}\n<\u002Fstyle>\n<\u002Fhead>\n<body>\n<div class=\"app\" id=\"app\">\n  <div class=\"canvas\">\n    <div class=\"titlebar\">\n      <span class=\"brand\" title=\"NVH Result Viewer\">📊 NVH<\u002Fspan>\n      <div class=\"tabs titlebar-tabs\" id=\"topTabs\"><\u002Fdiv>\n      <div class=\"titlebar-spacer\"><\u002Fdiv>\n      <button class=\"icon-btn\" id=\"saveBtn\" title=\"Save state to JSON\"><span class=\"ico\">💾<\u002Fspan><span class=\"lbl\">Save<\u002Fspan><\u002Fbutton>\n      <span class=\"title-sep\"><\u002Fspan>\n      <button class=\"btn btn-sm\" id=\"exportCurrentBtn\" title=\"Export current tab → 1 PPTX (1 slide, actual size)\"><span class=\"ico\">📄<\u002Fspan><span class=\"lbl\">Export tab<\u002Fspan><\u002Fbutton>\n      <button class=\"btn btn-sm\" id=\"exportPptxBtn\" title=\"Export ALL tabs → 1 PPTX (multi slides, actual size)\"><span class=\"ico\">📤<\u002Fspan><span class=\"lbl\">Export all→PPTX<\u002Fspan><\u002Fbutton>\n      <span class=\"info-pill\" id=\"dsInfo\">no workbook<\u002Fspan>\n      <button class=\"icon-btn\" id=\"toggleInspTop\" title=\"Toggle inspector panel\"><span class=\"ico\">▶<\u002Fspan><span class=\"lbl\">Inspector<\u002Fspan><\u002Fbutton>\n      <input type=\"file\" id=\"fileIn\" accept=\".xlsx,.xls,.csv,.json\" style=\"display:none\">\n    <\u002Fdiv>\n    <div class=\"ribbon\">\n      <div class=\"ctrl-group\" data-grp=\"layout\">\n        <div class=\"ctrl-row\">\n          <span class=\"ctrl-lbl\">Axes<\u002Fspan>\n          <div id=\"axBoxes\" style=\"display:flex;gap:6px\"><\u002Fdiv>\n        <\u002Fdiv>\n        <div class=\"layout-grid\">\n          <span class=\"ctrl-lbl\">Points<\u002Fspan>\n          <input type=\"number\" id=\"pointsN\" min=\"1\" max=\"10\" value=\"3\" style=\"width:54px;text-align:center\">\n          <span><\u002Fspan>\n          <span class=\"ctrl-lbl\">W<\u002Fspan>\n          <input type=\"number\" id=\"chartW\" min=\"180\" max=\"900\" value=\"320\" style=\"width:54px\">\n          <button class=\"btn btn-sm\" id=\"autoFitXBtn\" title=\"Auto-fit X-axis range to data\">⚡<\u002Fbutton>\n          <span class=\"ctrl-lbl\">H<\u002Fspan>\n          <input type=\"number\" id=\"chartH\" min=\"120\" max=\"650\" value=\"200\" style=\"width:54px\">\n          <button class=\"btn btn-sm\" id=\"autoFitYBtn\" title=\"Auto-fit Y-axis range to data\">⚡<\u002Fbutton>\n        <\u002Fdiv>\n        <span class=\"grp-label\">Layout<\u002Fspan>\n      <\u002Fdiv>\n      <div class=\"ctrl-group\" data-grp=\"view\">\n        <div class=\"ctrl-row\">\n          <label><span class=\"check checked\" id=\"cbGrid\">✓<\u002Fspan> Gridlines<\u002Flabel>\n        <\u002Fdiv>\n        <div class=\"ctrl-row\">\n          <label><span class=\"check checked\" id=\"cbLeg\">✓<\u002Fspan> Legend<\u002Flabel>\n        <\u002Fdiv>\n        <div class=\"ctrl-row\">\n          <span class=\"ctrl-lbl\" title=\"Spacing between charts (px)\">Gap<\u002Fspan>\n          <input type=\"number\" id=\"exportGap\" value=\"12\" min=\"0\" max=\"200\" style=\"width:54px\" data-comment-anchor=\"256669ecd1-input\">\n        <\u002Fdiv>\n        <span class=\"grp-label\">View<\u002Fspan>\n      <\u002Fdiv>\n      <div class=\"ctrl-group\" data-grp=\"analysis\">\n        <div class=\"ctrl-row\">\n          <label><span class=\"check\" id=\"cbPeak\"><\u002Fspan> Peak detection<\u002Flabel>\n          <label><span class=\"check checked\" id=\"cbPeakLabel\">✓<\u002Fspan> Peak labels<\u002Flabel>\n        <\u002Fdiv>\n        <div class=\"ctrl-row\">\n          <span class=\"ctrl-lbl\" style=\"font-weight:600\">Peak ranges<\u002Fspan>\n          <button class=\"btn btn-sm\" id=\"addPeakRangeBtn\">+ Add<\u002Fbutton>\n        <\u002Fdiv>\n        <div id=\"peakRangesList\" class=\"peak-ranges\"><\u002Fdiv>\n        <span class=\"grp-label\">Analysis<\u002Fspan>\n      <\u002Fdiv>\n      <div class=\"ctrl-group\" data-grp=\"scale\" data-comment-anchor=\"341ff742bc-div\">\n        <div class=\"scale-grid\">\n          <span class=\"small muted\"><\u002Fspan>\n          <span class=\"small muted\">Min<\u002Fspan>\n          <span class=\"small muted\">Max<\u002Fspan>\n          <span class=\"small muted\">Major<\u002Fspan>\n          <label class=\"ctrl-lbl\">Y<\u002Flabel>\n          <input type=\"number\" id=\"yMin\" value=\"30\" style=\"width:54px\">\n          <input type=\"number\" id=\"yMax\" value=\"90\" style=\"width:54px\">\n          <input type=\"number\" id=\"yMaj\" value=\"10\" style=\"width:54px\">\n          <label class=\"ctrl-lbl\">X<\u002Flabel>\n          <input type=\"number\" id=\"xMin\" value=\"0\" style=\"width:54px\">\n          <input type=\"number\" id=\"xMax\" value=\"2000\" style=\"width:54px\">\n          <input type=\"number\" id=\"xMaj\" value=\"500\" style=\"width:54px\">\n        <\u002Fdiv>\n        <div class=\"ctrl-row\">\n          <button class=\"btn btn-sm\" id=\"applyScaleAllBtn\">Apply to all tabs<\u002Fbutton>\n        <\u002Fdiv>\n        <span class=\"grp-label\">Scale<\u002Fspan>\n      <\u002Fdiv>\n    <\u002Fdiv>\n    <div id=\"gridHost\" style=\"margin-top:8px;overflow-x:auto;overflow-y:hidden;padding-bottom:6px;\"><\u002Fdiv>\n    <div id=\"legendHost\"><\u002Fdiv>\n  <\u002Fdiv>\n\n  <div class=\"grip\" id=\"grip\"><\u002Fdiv>\n  <div class=\"insp\" id=\"insp\">\n    <div class=\"ih\">\n      <span>Inspector<\u002Fspan>\n      <span style=\"display:flex;align-items:center;gap:8px\">\n        <span class=\"muted small\" id=\"selInfo\">all charts<\u002Fspan>\n        <span class=\"ih-close\" id=\"hideInsp\" title=\"Hide inspector\">▶<\u002Fspan>\n      <\u002Fspan>\n    <\u002Fdiv>\n\n    <div class=\"insp-tabs\">\n      <div class=\"insp-tab active\" data-itab=\"setup\">Setup<\u002Fdiv>\n      <div class=\"insp-tab\" data-itab=\"labels\">Labels &amp; Tabs<\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"insp-page active\" data-ipage=\"setup\">\n\n    <div class=\"sec\">\n      <h3>Workbook · Sheets<\u002Fh3>\n      <div class=\"body\">\n        <div class=\"drop\" id=\"drop\">📁 Drop XLSX / CSV / JSON here · or click to browse<\u002Fdiv>\n        <div id=\"sheetList\" class=\"small muted\">No sheets loaded.<\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <div class=\"sec\">\n      <h3>Models · <span id=\"lineCount\" class=\"muted small\">0<\u002Fspan><\u002Fh3>\n      <div class=\"body\">\n        <div class=\"muted small\" style=\"line-height:1.4\">\n          One model per row. Per model: pick the sheet, the X column (Excel letter), the row range, and which Y column letter feeds each (axis · point) cell.\n        <\u002Fdiv>\n        <table class=\"t\" id=\"linesTable\">\n          <thead><tr><th><\u002Fth><th>Color<\u002Fth><th colspan=\"3\">Name<\u002Fth><th colspan=\"2\">Sheet<\u002Fth><th><\u002Fth><\u002Ftr><\u002Fthead>\n          <tbody><\u002Ftbody>\n        <\u002Ftable>\n        <button class=\"btn\" id=\"addLineBtn\">＋ Add model<\u002Fbutton>\n      <\u002Fdiv>\n    <\u002Fdiv>\n\n    <\u002Fdiv><!-- /setup page -->\n\n    <div class=\"insp-page\" data-ipage=\"labels\">\n      <div class=\"sec\">\n        <h3>Axis Titles<\u002Fh3>\n        <div class=\"body\">\n          <div class=\"row-2\"><label>X title<\u002Flabel><input type=\"text\" id=\"xLab\" value=\"Frequency (Hz)\"><\u002Fdiv>\n          <div class=\"row-2\"><label>Y title<\u002Flabel><input type=\"text\" id=\"yLab\" value=\"Acc (m/s²)\"><\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"sec\">\n        <h3>Axis Names (X / Y / Z)<\u002Fh3>\n        <div class=\"body\" id=\"axNamesBody\"><\u002Fdiv>\n      <\u002Fdiv>\n      <div class=\"sec\">\n        <h3>Point Names<\u002Fh3>\n        <div class=\"body\" id=\"ptNamesBody\"><\u002Fdiv>\n      <\u002Fdiv>\n    <\u002Fdiv><!-- /labels page -->\n    <button class=\"btn primary insp-toggle-bottom\" id=\"toggleInsp\">⇆ Inspector<\u002Fbutton>\n  <\u002Fdiv>\n  <div class=\"reopen\" id=\"reopen\" title=\"Show inspector\">◀  INSPECTOR<\u002Fdiv>\n<\u002Fdiv>\n\n<div class=\"status\" id=\"statusBar\">\n  <span id=\"status1\">Ready<\u002Fspan>\n  <span>·<\u002Fspan>\n  <span id=\"status2\"><\u002Fspan>\n  <span style=\"margin-left:auto\" class=\"muted\">NVH Viewer v2<\u002Fspan>\n<\u002Fdiv>\n\n<div id=\"popHost\"><\u002Fdiv>\n<div id=\"ttHost\"><\u002Fdiv>\n\n<script>\n// ───── State ──────────────────────────────────────────────\n// Model = 1 sheet of data → produces 1 line per (point, axis) cell.\n// Per model: name, color, sheet, X col (Excel letter), row range (row1-row2),\n// and a mapping {pointN_axis: Y col letter} that says which column has Y for that cell.\nconst state = {\n  workbook: null,                 // {sheets:{name: [[...rows]]}, names:[...]}\n  axes: ['X','Y','Z'],\n  axisNames: {X:'X', Y:'Y', Z:'Z'},\n  pointCount: 3,\n  pointNames: {},                 // {1:'POINT 1', 2:'POINT 2', ...}\n  chartW: 320, chartH: 200,\n  models: [],\n  tabs: [\n    {id:'fr',  name:'Frequency Response', kind:'chart', xLabel:'Frequency (Hz)', yLabel:'Acc (m/s²)'},\n    {id:'td',  name:'Time Domain',        kind:'chart', xLabel:'Time (s)',       yLabel:'Amplitude'},\n    {id:'oct', name:'1/3 Octave Band',    kind:'chart', xLabel:'1/3 Octave Band (Hz)', yLabel:'Level (dB)'},\n    {id:'mode',name:'Mode Shapes',        kind:'modeshape'},\n  ],\n  activeTab:'fr',\n  yMin:30,yMax:90,yMaj:10,xMin:0,xMax:2000,xMaj:500,\n  peakXMin:0, peakXMax:2000,\n  peakRanges:[{min:0, max:2000}],\n  peakLabelOffsets:{},\n  showGrid:true, showLegend:true, showPeaks:false, showPeakLabels:true,\n  xLabel:'Frequency (Hz)', yLabel:'Acc (m/s²)',\n  exportGap: 12,\n  selectedCell:null,\n};\n\nconst COLORS = ['#000000','#c00000','#5da438','#2b6cb0','#7030a0','#e89542','#000080','#008080','#800000','#404040'];\nlet nextModelId = 1;\n\nconst TAB_STATE_KEYS = [\n  'workbook','axes','axisNames','pointCount','pointNames','models',\n  'yMin','yMax','yMaj','xMin','xMax','xMaj','peakXMin','peakXMax','peakRanges','peakLabelOffsets',\n  'showGrid','showLegend','showPeaks','showPeakLabels','xLabel','yLabel',\n  'chartW','chartH'\n];\n\nfunction clonePlain(v){\n  return v == null ? v : JSON.parse(JSON.stringify(v));\n}\n\nfunction makeDefaultTabState(tab={}){\n  return {\n    workbook: null,\n    axes: ['X','Y','Z'],\n    axisNames: {X:'X', Y:'Y', Z:'Z'},\n    pointCount: 3,\n    pointNames: {},\n    models: [],\n    yMin:30,yMax:90,yMaj:10,xMin:0,xMax:2000,xMaj:500,\n    peakXMin:0, peakXMax:2000,\n    peakRanges:[{min:0, max:2000}],\n    peakLabelOffsets:{},\n    showGrid:true, showLegend:true, showPeaks:false, showPeakLabels:true,\n    xLabel: tab.xLabel || 'Frequency (Hz)',\n    yLabel: tab.yLabel || 'Acc (m/s²)',\n    chartW: 320, chartH: 200\n  };\n}\n\nfunction ensureTabState(tab){\n  const defaults = makeDefaultTabState(tab);\n  for(const key of TAB_STATE_KEYS){\n    if(tab[key] === undefined) tab[key] = clonePlain(defaults[key]);\n  }\n  if(!Array.isArray(tab.peakRanges) || !tab.peakRanges.length){\n    tab.peakRanges = [{min: tab.peakXMin ?? 0, max: tab.peakXMax ?? 2000}];\n  }\n  return tab;\n}\n\nfunction normalizePeakRanges(){\n  if(!Array.isArray(state.peakRanges) || !state.peakRanges.length){\n    state.peakRanges = [{min: state.peakXMin ?? 0, max: state.peakXMax ?? 2000}];\n  }\n  state.peakRanges = state.peakRanges.map(r=>({\n    min: Number.isFinite(+r.min) ? +r.min : 0,\n    max: Number.isFinite(+r.max) ? +r.max : 0\n  }));\n  state.peakXMin = state.peakRanges[0].min;\n  state.peakXMax = state.peakRanges[0].max;\n}\n\nfunction getYUnit(){\n  const lbl = state.yLabel || '';\n  const m = lbl.match(/\\(([^)]+)\\)/);\n  return m ? m[1].trim() : lbl.trim();\n}\n\nfunction renderPeakRangesList(){\n  const host = document.getElementById('peakRangesList');\n  if(!host) return;\n  normalizePeakRanges();\n  host.innerHTML = '';\n  state.peakRanges.forEach((r, idx)=>{\n    const row = document.createElement('div');\n    row.className = 'peak-range-row';\n    row.innerHTML = `\n      <label class=\"small muted\">#${idx+1}<\u002Flabel>\n      <input type=\"number\" class=\"pkMin\" data-idx=\"${idx}\" value=\"${r.min}\">\n      <input type=\"number\" class=\"pkMax\" data-idx=\"${idx}\" value=\"${r.max}\">\n      <button class=\"btn rmRange\" data-idx=\"${idx}\" title=\"Remove range\" ${state.peakRanges.length<=1?'disabled':''}>×<\u002Fbutton>`;\n    host.appendChild(row);\n  });\n  host.querySelectorAll('.pkMin').forEach(inp=>{\n    inp.addEventListener('change', e=>{\n      const i = +e.target.dataset.idx;\n      state.peakRanges[i].min = parseFloat(e.target.value);\n      normalizePeakRanges();\n      render();\n    });\n  });\n  host.querySelectorAll('.pkMax').forEach(inp=>{\n    inp.addEventListener('change', e=>{\n      const i = +e.target.dataset.idx;\n      state.peakRanges[i].max = parseFloat(e.target.value);\n      normalizePeakRanges();\n      render();\n    });\n  });\n  host.querySelectorAll('.rmRange').forEach(btn=>{\n    btn.addEventListener('click', e=>{\n      const i = +e.currentTarget.dataset.idx;\n      if(state.peakRanges.length <= 1) return;\n      state.peakRanges.splice(i, 1);\n      normalizePeakRanges();\n      renderPeakRangesList();\n      render();\n    });\n  });\n}\n\nfunction getActiveTab(){\n  return state.tabs.find(t=>t.id===state.activeTab) || state.tabs[0];\n}\n\nfunction saveActiveTabState(){\n  const tab = getActiveTab();\n  if(!tab) return;\n  ensureTabState(tab);\n  for(const key of TAB_STATE_KEYS) tab[key] = clonePlain(state[key]);\n}\n\nfunction loadTabState(tab){\n  ensureTabState(tab);\n  for(const key of TAB_STATE_KEYS) state[key] = clonePlain(tab[key]);\n  syncControlsFromState();\n}\n\nfunction syncControlsFromState(){\n  for(const id of ['yMin','yMax','yMaj','xMin','xMax','xMaj']){\n    const el = document.getElementById(id);\n    if(el && state[id] != null) el.value = state[id];\n  }\n  renderPeakRangesList();\n  const points = document.getElementById('pointsN');\n  if(points) points.value = state.pointCount;\n  const chartW = document.getElementById('chartW');\n  if(chartW) chartW.value = state.chartW || 320;\n  const chartH = document.getElementById('chartH');\n  if(chartH) chartH.value = state.chartH || 200;\n  const xLab = document.getElementById('xLab');\n  if(xLab) xLab.value = state.xLabel;\n  const yLab = document.getElementById('yLab');\n  if(yLab) yLab.value = state.yLabel;\n  const cbGrid = document.getElementById('cbGrid');\n  if(cbGrid){ cbGrid.className = 'check' + (state.showGrid?' checked':''); cbGrid.textContent = state.showGrid?'✓':''; }\n  const cbLeg = document.getElementById('cbLeg');\n  if(cbLeg){ cbLeg.className = 'check' + (state.showLegend?' checked':''); cbLeg.textContent = state.showLegend?'✓':''; }\n  const cbPeak = document.getElementById('cbPeak');\n  if(cbPeak){ cbPeak.className = 'check' + (state.showPeaks?' checked':''); cbPeak.textContent = state.showPeaks?'✓':''; }\n  const cbPeakLabel = document.getElementById('cbPeakLabel');\n  if(cbPeakLabel){ cbPeakLabel.className = 'check' + (state.showPeakLabels?' checked':''); cbPeakLabel.textContent = state.showPeakLabels?'✓':''; }\n  const chartSizeInfo = document.getElementById('chartSizeInfo');\n  if(chartSizeInfo) chartSizeInfo.textContent = `Chart size: ${state.chartW || 320} × ${state.chartH || 200} px.`;\n}\n\nfunction initializeTabState(){\n  for(const tab of state.tabs) ensureTabState(tab);\n  loadTabState(getActiveTab());\n}\n\n// Excel column letters ⇄ index\nfunction colLetter(i){ // 0→A, 1→B, 25→Z, 26→AA\n  let s=''; i = +i;\n  if(isNaN(i)||i<0) return '';\n  do { s = String.fromCharCode(65 + (i%26)) + s; i = Math.floor(i/26)-1; } while(i>=0);\n  return s;\n}\nfunction colIndex(s){ // 'A'→0, 'AA'→26\n  if(s==null) return -1;\n  s = String(s).trim().toUpperCase();\n  if(!/^[A-Z]+$/.test(s)) return -1;\n  let n = 0;\n  for(const ch of s) n = n*26 + (ch.charCodeAt(0)-64);\n  return n-1;\n}\n\n// ───── Sample workbook generator ─────────────────────────\nfunction buildSampleWorkbook(){\n  const sheets = {};\n  const names = ['model_1','model_2','model_3'];\n  const peakBases = [[180,460,880,1380],[200,510,940,1500],[220,440,860,1420]];\n  const baseLevels = [58, 52, 64];\n  for(let mi=0; mi<3; mi++){\n    // header: Freq, P1_X, P1_Y, P1_Z, P2_X, P2_Y, P2_Z, P3_X, P3_Y, P3_Z\n    const header = ['Frequency'];\n    for(let pi=1; pi<=3; pi++) for(const a of ['X','Y','Z']) header.push(`P${pi}_${a}`);\n    const rows = [header];\n    for(let f=0; f<=2000; f+=5){\n      const row = [f];\n      for(let pi=0; pi<3; pi++) for(let ai=0; ai<3; ai++){\n        let y = baseLevels[mi] + pi*2 - ai*3 - f/2000*15;\n        for(const pk of peakBases[mi]){\n          y += 18 * Math.exp(-Math.pow((f-pk-pi*20-ai*10)/80,2)/2);\n        }\n        y += (Math.sin(f/30 + mi*7 + pi*3 + ai)*2);\n        y += (Math.random()-0.5)*5;\n        row.push(+y.toFixed(2));\n      }\n      rows.push(row);\n    }\n    sheets[names[mi]] = rows;\n  }\n  return {sheets, names};\n}\n\n// ───── XLSX file loader ─────────────────────────────────\nasync function loadFile(file){\n  if(file && /\\.json$/i.test(file.name)){\n    return loadResultFile(file);\n  }\n  const buf = await file.arrayBuffer();\n  const wb = XLSX.read(buf,{type:'array'});\n  const sheets = {};\n  for(const name of wb.SheetNames){\n    sheets[name] = XLSX.utils.sheet_to_json(wb.Sheets[name],{header:1});\n  }\n  state.workbook = {sheets, names: wb.SheetNames};\n  state.models = [];\n  autoCreateModels();\n  saveActiveTabState();\n  render();\n}\n\nfunction autoCreateModels(){\n  if(!state.workbook) return;\n  const {sheets, names} = state.workbook;\n  state.models = [];\n  let ci = 0;\n  for(const sheetName of names){\n    const rows = sheets[sheetName];\n    if(!rows || rows.length<2) continue;\n    const header = rows[0];\n    // detect mapping by header tags\n    const mapping = {};\n    for(let i=1; i<header.length; i++){\n      const h = String(header[i]||'');\n      const m = h.match(/p(?:oint)?\\s*[\\.\\-_ ]?\\s*(\\d+)/i);\n      const a = h.match(/(?:^|[^a-z])([xyz])(?:[^a-z]|$)/i);\n      const point = m ? +m[1] : (Math.floor((i-1)/3)+1);\n      const axis = a ? a[1].toUpperCase() : ['X','Y','Z'][(i-1)%3];\n      mapping[`P${point}_${axis}`] = i;\n    }\n    state.models.push({\n      id: nextModelId++, name: sheetName, color: COLORS[ci % COLORS.length],\n      visible:true, lineWeight:1, sheet: sheetName,\n      xCol: 0,                   // column index for X (frequency)\n      rowStart: 2,               // 1-indexed (Excel-style); row 1 = header\n      rowEnd:   rows.length,     // inclusive\n      mapping,                   // {P1_X: colIndex, ...}\n    });\n    ci++;\n  }\n}\n\nfunction loadSample(){\n  state.workbook = buildSampleWorkbook();\n  state.models = [];\n  autoCreateModels();\n  saveActiveTabState();\n  render();\n}\n\n// ───── Helpers ──────────────────────────────────────────\nfunction getModelLine(model, point, axis){\n  // resolve which Y column this (point,axis) maps to for this model\n  const yCol = model.mapping[`P${point}_${axis}`];\n  if(yCol == null || yCol < 0) return [];\n  const rows = state.workbook && state.workbook.sheets[model.sheet];\n  if(!rows) return [];\n  // row range is 1-indexed in Excel; row 1 = header, data starts row 2 by default\n  const r0 = Math.max(1, (model.rowStart|0) - 1);  // -1 to convert to 0-indexed array; clamp at 1 (skip header)\n  const r1 = Math.min(rows.length-1, (model.rowEnd|0) - 1);\n  const data = [];\n  for(let r = r0; r <= r1; r++){\n    const x = parseFloat(rows[r][model.xCol]);\n    const y = parseFloat(rows[r][yCol]);\n    if(!isNaN(x) && !isNaN(y)) data.push([x,y]);\n  }\n  return data;\n}\n\nfunction findPeakArr(data, xMin=state.peakXMin, xMax=state.peakXMax){\n  if(!data || data.length<5) return null;\n  const lo = Math.min(xMin, xMax), hi = Math.max(xMin, xMax);\n  let best = null;\n  for(let i=2; i<data.length-2; i++){\n    const [x,y] = data[i];\n    if(x < lo || x > hi) continue;\n    if(y > data[i-1][1] && y > data[i+1][1] && y > data[i-2][1] && y > data[i+2][1]){\n      if(!best || y > best.y) best = {x, y};\n    }\n  }\n  return best;\n}\n\n// ───── Chart drawing (SVG) ──────────────────────────────\nfunction drawChart(point, axis, w, h){\n  const padL=44, padR=10, padT=20, padB=32;\n  const pw = w - padL - padR, ph = h - padT - padB;\n  const ns = 'http://www.w3.org/2000/svg';\n  const svg = document.createElementNS(ns,'svg');\n  svg.setAttribute('xmlns', 'http://www.w3.org/2000/svg');\n  svg.setAttribute('width', w); svg.setAttribute('height', h);\n  svg.setAttribute('viewBox', `0 0 ${w} ${h}`);\n  svg.style.background = '#fff';\n  svg.style.fontFamily = '\"Meiryo UI\",Meiryo,sans-serif';\n\n  const xPx = x => ((x-state.xMin)/(state.xMax-state.xMin))*pw;\n  const yPx = y => ph - ((y-state.yMin)/(state.yMax-state.yMin))*ph;\n\n  // outer\n  const outer = document.createElementNS(ns,'rect');\n  outer.setAttribute('x',0.5); outer.setAttribute('y',0.5);\n  outer.setAttribute('width', w-1); outer.setAttribute('height', h-1);\n  outer.setAttribute('fill','#fff'); outer.setAttribute('stroke','none');\n  svg.appendChild(outer);\n\n  // title\n  const t = document.createElementNS(ns,'text');\n  t.setAttribute('x', w/2); t.setAttribute('y', 13); t.setAttribute('text-anchor','middle');\n  t.setAttribute('font-size','11');\n  const axName = state.axisNames[axis] || axis;\n  const ptName = state.pointNames[point] || `POINT ${point}`;\n  t.textContent = `${axName} - ${ptName}`;\n  svg.dataset.title = t.textContent;\n  svg.appendChild(t);\n\n  // plot group\n  const g = document.createElementNS(ns,'g');\n  g.setAttribute('transform', `translate(${padL},${padT})`);\n  svg.appendChild(g);\n\n  // plot bg + border\n  const pa = document.createElementNS(ns,'rect');\n  pa.setAttribute('x',0); pa.setAttribute('y',0); pa.setAttribute('width',pw); pa.setAttribute('height',ph);\n  pa.setAttribute('fill','#fff'); pa.setAttribute('stroke','#000'); pa.setAttribute('stroke-width','0.75');\n  g.appendChild(pa);\n\n  // gridlines\n  if(state.showGrid){\n    const gl = document.createElementNS(ns,'g');\n    gl.setAttribute('stroke','#bfbfbf'); gl.setAttribute('stroke-width','0.5'); gl.setAttribute('stroke-dasharray','2 2');\n    for(let v=state.yMin; v<=state.yMax+0.001; v+=state.yMaj){\n      if(v<=state.yMin || v>=state.yMax) continue;\n      const ln = document.createElementNS(ns,'line');\n      ln.setAttribute('x1',0); ln.setAttribute('x2',pw); ln.setAttribute('y1',yPx(v)); ln.setAttribute('y2',yPx(v));\n      gl.appendChild(ln);\n    }\n    for(let v=state.xMin; v<=state.xMax+0.001; v+=state.xMaj){\n      if(v<=state.xMin || v>=state.xMax) continue;\n      const ln = document.createElementNS(ns,'line');\n      ln.setAttribute('y1',0); ln.setAttribute('y2',ph); ln.setAttribute('x1',xPx(v)); ln.setAttribute('x2',xPx(v));\n      gl.appendChild(ln);\n    }\n    g.appendChild(gl);\n  }\n\n  // ticks\n  for(let v=state.xMin; v<=state.xMax+0.001; v+=state.xMaj){\n    const tk = document.createElementNS(ns,'line');\n    tk.setAttribute('x1',xPx(v)); tk.setAttribute('x2',xPx(v));\n    tk.setAttribute('y1',ph); tk.setAttribute('y2',ph-3);\n    tk.setAttribute('stroke','#000'); tk.setAttribute('stroke-width','0.75');\n    g.appendChild(tk);\n    const lbl = document.createElementNS(ns,'text');\n    const xAnchor = v >= state.xMax - 0.001 ? 'end' : v <= state.xMin + 0.001 ? 'start' : 'middle';\n    lbl.setAttribute('x',xPx(v)); lbl.setAttribute('y',ph+11); lbl.setAttribute('text-anchor', xAnchor);\n    lbl.setAttribute('font-size','9'); lbl.textContent = v;\n    g.appendChild(lbl);\n  }\n  for(let v=state.yMin; v<=state.yMax+0.001; v+=state.yMaj){\n    const tk = document.createElementNS(ns,'line');\n    tk.setAttribute('y1',yPx(v)); tk.setAttribute('y2',yPx(v));\n    tk.setAttribute('x1',0); tk.setAttribute('x2',3);\n    tk.setAttribute('stroke','#000'); tk.setAttribute('stroke-width','0.75');\n    g.appendChild(tk);\n    const lbl = document.createElementNS(ns,'text');\n    lbl.setAttribute('x',-4); lbl.setAttribute('y',yPx(v)+3); lbl.setAttribute('text-anchor','end');\n    lbl.setAttribute('font-size','9'); lbl.textContent = v;\n    g.appendChild(lbl);\n  }\n\n  // axis titles\n  const xt = document.createElementNS(ns,'text');\n  xt.setAttribute('x',pw/2); xt.setAttribute('y',ph+24); xt.setAttribute('text-anchor','middle');\n  xt.setAttribute('font-size','9.5'); xt.textContent = state.xLabel;\n  g.appendChild(xt);\n  const yt = document.createElementNS(ns,'text');\n  yt.setAttribute('x', -padL+12); yt.setAttribute('y',ph/2); yt.setAttribute('text-anchor','middle');\n  yt.setAttribute('font-size','9.5'); yt.setAttribute('transform',`rotate(-90 ${-padL+12} ${ph/2})`);\n  yt.textContent = state.yLabel;\n  g.appendChild(yt);\n\n  // clip\n  const clipId = `c${point}${axis}${Math.random().toString(36).slice(2,7)}`;\n  const defs = document.createElementNS(ns,'defs');\n  const cp = document.createElementNS(ns,'clipPath');\n  cp.setAttribute('id', clipId);\n  const cr = document.createElementNS(ns,'rect');\n  cr.setAttribute('x',0); cr.setAttribute('y',0); cr.setAttribute('width',pw); cr.setAttribute('height',ph);\n  cp.appendChild(cr); defs.appendChild(cp); svg.appendChild(defs);\n\n  const lg = document.createElementNS(ns,'g');\n  lg.setAttribute('clip-path', `url(#${clipId})`);\n  g.appendChild(lg);\n\n  // lines for this cell — one per visible model\n  const linesHere = [];\n  for(const m of state.models){\n    if(!m.visible) continue;\n    const data = getModelLine(m, point, axis);\n    if(!data.length) continue;\n    linesHere.push({model:m, data});\n  }\n  for(const {model, data} of linesHere){\n    const path = document.createElementNS(ns,'path');\n    let d = '';\n    for(let i=0;i<data.length;i++){\n      const [x,y] = data[i];\n      if(x<state.xMin||x>state.xMax) continue;\n      const px = xPx(x).toFixed(1);\n      const py = yPx(Math.max(state.yMin,Math.min(state.yMax,y))).toFixed(1);\n      d += (d?'L':'M')+px+' '+py+' ';\n    }\n    path.setAttribute('d', d);\n    path.setAttribute('stroke', model.color);\n    path.setAttribute('stroke-width', model.lineWeight);\n    path.setAttribute('fill','none');\n    path.setAttribute('stroke-linejoin','round');\n    lg.appendChild(path);\n  }\n\n  // peak vertical dashed line — 1 peak per range per model per point, vertical line crosses all 3 axes\n  const pendingLabels = [];\n  if(state.showPeaks){\n    const ranges = (Array.isArray(state.peakRanges) && state.peakRanges.length)\n      ? state.peakRanges\n      : [{min: state.peakXMin, max: state.peakXMax}];\n    const yUnit = getYUnit();\n\n    // Pre-compute pixel polylines for collision detection\n    const pxLines = linesHere.map(({data})=>{\n      const pts = [];\n      for(const [x,y] of data){\n        if(x<state.xMin || x>state.xMax) continue;\n        pts.push([xPx(x), yPx(Math.max(state.yMin,Math.min(state.yMax,y)))]);\n      }\n      return pts;\n    });\n\n    // Count how many line samples fall inside a box (line collision penalty)\n    function lineHits(box){\n      let c = 0;\n      for(const pts of pxLines){\n        for(let i=0;i<pts.length;i++){\n          const [pxq,pyq] = pts[i];\n          if(pxq>=box.x && pxq<=box.x+box.w && pyq>=box.y && pyq<=box.y+box.h) c++;\n        }\n      }\n      return c;\n    }\n\n    // First pass: collect every peak in this cell so we can place them together\n    const peakSet = [];\n    for(const m of state.models){\n      if(!m.visible) continue;\n      for(let ri=0; ri<ranges.length; ri++){\n        const rng = ranges[ri];\n        let best = null;\n        for(const ax of state.axes){\n          const d = getModelLine(m, point, ax);\n          const p = findPeakArr(d, rng.min, rng.max);\n          if(p && (!best || p.y > best.y)) best = p;\n        }\n        if(!best) continue;\n        const px = xPx(best.x);\n        if(px<0 || px>pw) continue;\n        // dashed vertical line\n        const vl = document.createElementNS(ns,'line');\n        vl.setAttribute('x1',px); vl.setAttribute('x2',px);\n        vl.setAttribute('y1',0); vl.setAttribute('y2',ph);\n        vl.setAttribute('stroke',m.color); vl.setAttribute('stroke-width','1');\n        vl.setAttribute('stroke-dasharray','3 2'); vl.setAttribute('opacity','0.85');\n        g.appendChild(vl);\n\n        const py = yPx(Math.max(state.yMin, Math.min(state.yMax, best.y)));\n        peakSet.push({m, ri, best, px, py});\n      }\n    }\n\n    if(state.showPeakLabels){\n      // Place labels in order of peak height (highest first → harder cases solved first)\n      peakSet.sort((a,b)=> b.best.y - a.best.y);\n      const placedBoxes = [];\n\n      for(const pk of peakSet){\n        const {m, ri, best, px, py} = pk;\n        const line1 = `X: ${Math.round(best.x)}Hz`;\n        const line2 = `Y: ${best.y.toFixed(1)}${yUnit ? ' '+yUnit : ''}`;\n        const charW = 5.2;\n        const boxW = Math.max(56, Math.max(line1.length, line2.length) * charW + 6);\n        const boxH = 24;\n        const gap = 8;\n\n        // Candidate anchor positions around the peak point\n        const candidates = [\n          {x: px+gap,            y: py-boxH-gap, dir:'NE'},\n          {x: px-boxW-gap,       y: py-boxH-gap, dir:'NW'},\n          {x: px+gap,            y: py+gap,      dir:'SE'},\n          {x: px-boxW-gap,       y: py+gap,      dir:'SW'},\n          {x: px-boxW/2,         y: py-boxH-gap*2,dir:'N' },\n          {x: px+gap,            y: py-boxH/2,   dir:'E' },\n          {x: px-boxW-gap,       y: py-boxH/2,   dir:'W' },\n          // fallbacks high in the chart\n          {x: px+gap,            y: 4,           dir:'top-R'},\n          {x: px-boxW-gap,       y: 4,           dir:'top-L'},\n          {x: Math.max(2, pw-boxW-2), y: 4,      dir:'top-far-R'},\n          {x: 2,                 y: 4,           dir:'top-far-L'},\n        ];\n\n        let bestBox = null, bestScore = Infinity;\n        for(const c of candidates){\n          const x = Math.max(2, Math.min(pw-boxW-2, c.x));\n          const y = Math.max(2, Math.min(ph-boxH-2, c.y));\n          const box = {x, y, w:boxW, h:boxH};\n          let score = 0;\n          // Heavy penalty for landing on a curve\n          score += lineHits(box) * 12;\n          // Penalty for overlapping previously placed label boxes\n          for(const pb of placedBoxes){\n            const ox = Math.max(0, Math.min(box.x+box.w, pb.x+pb.w) - Math.max(box.x, pb.x));\n            const oy = Math.max(0, Math.min(box.y+box.h, pb.y+pb.h) - Math.max(box.y, pb.y));\n            score += ox*oy * 0.4;\n          }\n          // Small bias toward staying near the peak\n          const cx = box.x + box.w/2, cy = box.y + box.h/2;\n          score += Math.hypot(cx-px, cy-py) * 0.03;\n          // Tiny tiebreak: prefer NE/NW (above) over below\n          if(c.dir==='SE' || c.dir==='SW') score += 1.5;\n          if(score < bestScore){ bestScore = score; bestBox = box; }\n        }\n\n        const baseLx = bestBox.x, baseLy = bestBox.y;\n        placedBoxes.push(bestBox);\n\n        const key = `${point}:${axis}:${ri}:${m.id}`;\n        const off = (state.peakLabelOffsets && state.peakLabelOffsets[key]) || {dx:0, dy:0};\n        const lx = baseLx + (off.dx||0);\n        const ly = baseLy + (off.dy||0);\n        pendingLabels.push({lx, ly, boxW, boxH, line1, line2, color:m.color, key, baseLx, baseLy, px, py, pw, ph});\n      }\n    }\n  }\n\n  // hover overlay\n  const overlay = document.createElementNS(ns,'rect');\n  overlay.setAttribute('x',0); overlay.setAttribute('y',0); overlay.setAttribute('width',pw); overlay.setAttribute('height',ph);\n  overlay.setAttribute('fill','transparent');\n  overlay.style.cursor = 'crosshair';\n  overlay.addEventListener('mousemove', (e)=>{\n    const r = overlay.getBoundingClientRect();\n    const lx = e.clientX - r.left;\n    const x = state.xMin + (lx / pw) * (state.xMax - state.xMin);\n    const rows = linesHere.map(({model, data})=>{\n      let bd = data[0], bdd = Math.abs(bd[0]-x);\n      for(const d of data){const dd=Math.abs(d[0]-x); if(dd<bdd){bd=d;bdd=dd;}}\n      return {name: model.name, color: model.color, x:bd[0], y:bd[1]};\n    });\n    showTooltip(e.clientX+12, e.clientY+12, `${axis}·POINT ${point} · ${x.toFixed(0)} Hz`, rows);\n  });\n  overlay.addEventListener('mouseleave', ()=> hideTooltip());\n  g.appendChild(overlay);\n\n  // append peak labels AFTER overlay so they sit on top and grab pointer events\n  for(const info of pendingLabels){\n    const lblG = document.createElementNS(ns,'g');\n    lblG.setAttribute('class','peak-label');\n    lblG.style.cursor = 'move';\n    const box = document.createElementNS(ns,'rect');\n    box.setAttribute('x', info.lx); box.setAttribute('y', info.ly);\n    box.setAttribute('width', info.boxW); box.setAttribute('height', info.boxH);\n    box.setAttribute('fill', '#fffffd'); box.setAttribute('stroke', info.color);\n    box.setAttribute('stroke-width', '0.8'); box.setAttribute('opacity', '0.95');\n    lblG.appendChild(box);\n    const lbl = document.createElementNS(ns,'text');\n    lbl.setAttribute('x', info.lx + 3); lbl.setAttribute('y', info.ly + 10);\n    lbl.setAttribute('font-size','9'); lbl.setAttribute('fill', info.color);\n    lbl.style.userSelect = 'none';\n    const t1 = document.createElementNS(ns,'tspan');\n    t1.setAttribute('x', info.lx + 3); t1.setAttribute('dy','0');\n    t1.textContent = info.line1;\n    const t2 = document.createElementNS(ns,'tspan');\n    t2.setAttribute('x', info.lx + 3); t2.setAttribute('dy','11');\n    t2.textContent = info.line2;\n    lbl.appendChild(t1); lbl.appendChild(t2);\n    lblG.appendChild(lbl);\n    attachPeakLabelDrag(lblG, info);\n    g.appendChild(lblG);\n  }\n\n  return svg;\n}\n\nfunction attachPeakLabelDrag(group, info){\n  group.addEventListener('pointerdown', (ev)=>{\n    if(ev.button !== 0) return;\n    ev.stopPropagation(); ev.preventDefault();\n    const svgEl = group.ownerSVGElement;\n    const ctm = svgEl.getScreenCTM();\n    const sx = ctm ? ctm.a : 1;\n    const sy = ctm ? ctm.d : 1;\n    const startCX = ev.clientX, startCY = ev.clientY;\n    let curDx = 0, curDy = 0;\n    const onMove = (e)=>{\n      curDx = (e.clientX - startCX) / sx;\n      curDy = (e.clientY - startCY) / sy;\n      group.setAttribute('transform', `translate(${curDx},${curDy})`);\n    };\n    const onUp = ()=>{\n      window.removeEventListener('pointermove', onMove);\n      window.removeEventListener('pointerup', onUp);\n      const finalLx = info.lx + curDx;\n      const finalRx = finalLx + info.boxW;\n      const distLeft  = Math.abs(finalLx - info.px);\n      const distRight = Math.abs(finalRx - info.px);\n      const targetLx = (distLeft <= distRight)\n        ? info.px                       // snap left edge to peak line\n        : (info.px - info.boxW);        // snap right edge to peak line\n      const snappedDx = targetLx - info.baseLx;\n      const finalLy = info.ly + curDy;\n      const clampedLy = Math.max(0, Math.min(info.ph - info.boxH, finalLy));\n      const snappedDy = clampedLy - info.baseLy;\n      if(!state.peakLabelOffsets) state.peakLabelOffsets = {};\n      state.peakLabelOffsets[info.key] = {dx: snappedDx, dy: snappedDy};\n      saveActiveTabState();\n      render();\n    };\n    window.addEventListener('pointermove', onMove);\n    window.addEventListener('pointerup', onUp);\n  });\n}\n\nfunction showTooltip(x,y,title,rows){\n  const host = document.getElementById('ttHost');\n  host.innerHTML = '';\n  const t = document.createElement('div');\n  t.className = 'tt';\n  t.style.left = x+'px'; t.style.top = y+'px';\n  let html = `<div class=\"h\">${title}<\u002Fdiv>`;\n  for(const r of rows){\n    html += `<div style=\"display:flex;align-items:center;gap:5px\"><span style=\"display:inline-block;width:12px;height:2px;background:${r.color}\"><\u002Fspan>${r.name}: <b>${r.y.toFixed(1)}<\u002Fb><\u002Fdiv>`;\n  }\n  t.innerHTML = html;\n  host.appendChild(t);\n}\nfunction hideTooltip(){ document.getElementById('ttHost').innerHTML=''; }\n\nfunction downloadTextFile(filename, content, mime='text/plain'){\n  const blob = new Blob([content], {type: mime});\n  const url = URL.createObjectURL(blob);\n  const a = document.createElement('a');\n  a.href = url;\n  a.download = filename;\n  document.body.appendChild(a);\n  a.click();\n  a.remove();\n  URL.revokeObjectURL(url);\n}\n\nfunction svgToPngDataUrl(svg, scale = 4){\n  return new Promise((resolve, reject)=>{\n    const clone = svg.cloneNode(true);\n    const baseW = svg.viewBox.baseVal.width || +svg.getAttribute('width');\n    const baseH = svg.viewBox.baseVal.height || +svg.getAttribute('height');\n    if(!clone.getAttribute('xmlns')) clone.setAttribute('xmlns', 'http://www.w3.org/2000/svg');\n    if(!clone.getAttribute('viewBox')) clone.setAttribute('viewBox', `0 0 ${baseW} ${baseH}`);\n    clone.setAttribute('width', baseW);\n    clone.setAttribute('height', baseH);\n    const xml = new XMLSerializer().serializeToString(clone);\n    const blob = new Blob([xml], {type:'image/svg+xml;charset=utf-8'});\n    const url = URL.createObjectURL(blob);\n    const img = new Image();\n    img.onload = ()=>{\n      const canvas = document.createElement('canvas');\n      canvas.width = Math.round(baseW * scale);\n      canvas.height = Math.round(baseH * scale);\n      const ctx = canvas.getContext('2d');\n      ctx.imageSmoothingEnabled = true;\n      ctx.imageSmoothingQuality = 'high';\n      ctx.fillStyle = '#fff';\n      ctx.fillRect(0,0,canvas.width,canvas.height);\n      ctx.setTransform(scale, 0, 0, scale, 0, 0);\n      ctx.drawImage(img, 0, 0, baseW, baseH);\n      URL.revokeObjectURL(url);\n      resolve(canvas.toDataURL('image/png'));\n    };\n    img.onerror = err=>{ URL.revokeObjectURL(url); reject(err); };\n    img.src = url;\n  });\n}\n\nconst PX_PER_INCH = 96;\nconst px2in = px => px / PX_PER_INCH;\n\nfunction getExportGapPx(){\n  const v = +state.exportGap;\n  return Number.isFinite(v) && v >= 0 ? v : 12;\n}\n\nfunction computeTabContentSizePx(tab){\n  const axesN  = Math.max(1, (tab.axes || ['X','Y','Z']).length);\n  const pointsN = Math.max(1, tab.pointCount || 1);\n  const cw = tab.chartW || 320;\n  const ch = tab.chartH || 200;\n  const gap = getExportGapPx();\n  const margin = 16;\n  const titleH = 26;\n  const w = margin*2 + pointsN*cw + (pointsN-1)*gap;\n  const h = margin*2 + titleH + axesN*ch + (axesN-1)*gap;\n  return {w, h, axesN, pointsN, cw, ch, gap, margin, titleH};\n}\n\nasync function buildSlideForTab(pptx, tab, slideW_in){\n  state.activeTab = tab.id;\n  loadTabState(tab);\n  renderTopTabs();\n  renderLabelsPage();\n  render();\n  await new Promise(r=>requestAnimationFrame(()=>r()));\n  if((tab.kind||'chart') === 'modeshape'){\n    await ModeShapes.exportSlide(pptx, tab, slideW_in);\n    return;\n  }\n  const svgs = Array.from(document.querySelectorAll('#gridHost svg'));\n  const sz = computeTabContentSizePx(tab);\n  const slide = pptx.addSlide();\n  slide.background = {color:'FFFFFF'};\n  slide.addText(tab.name || 'NVH Result', {\n    x: px2in(sz.margin),\n    y: px2in(4),\n    w: slideW_in - 2*px2in(sz.margin),\n    h: px2in(sz.titleH - 4),\n    fontFace:'Meiryo UI', fontSize:13, bold:true, color:'1D4D80'\n  });\n  for(let i=0; i<svgs.length; i++){\n    const data = await svgToPngDataUrl(svgs[i]);\n    const col = i % sz.pointsN;\n    const row = Math.floor(i / sz.pointsN);\n    const xpx = sz.margin + col*(sz.cw + sz.gap);\n    const ypx = sz.margin + sz.titleH + row*(sz.ch + sz.gap);\n    slide.addImage({\n      data,\n      x: px2in(xpx),\n      y: px2in(ypx),\n      w: px2in(sz.cw),\n      h: px2in(sz.ch)\n    });\n  }\n}\n\nasync function exportTabsToPptx(tabs, fnameSuffix){\n  const PptxGen = typeof pptxgen !== 'undefined' ? pptxgen\n                : typeof PptxGenJS !== 'undefined' ? PptxGenJS\n                : null;\n  if(!PptxGen){\n    alert('PPTX export is unavailable because pptxgenjs is not included in the current project libraries.');\n    return;\n  }\n  if(!tabs || !tabs.length) return;\n  saveActiveTabState();\n  const originalTab = state.activeTab;\n  const pptx = new PptxGen();\n  pptx.author = 'NVH Result Viewer';\n  let maxW = 0, maxH = 0;\n  for(const t of tabs){\n    ensureTabState(t);\n    const s = computeTabContentSizePx(t);\n    if(s.w > maxW) maxW = s.w;\n    if(s.h > maxH) maxH = s.h;\n  }\n  const slideW_in = px2in(maxW);\n  const slideH_in = px2in(maxH);\n  pptx.defineLayout({name:'NVH_ACTUAL', width: slideW_in, height: slideH_in});\n  pptx.layout = 'NVH_ACTUAL';\n  try{\n    for(const tab of tabs){\n      await buildSlideForTab(pptx, tab, slideW_in);\n    }\n    const stamp = new Date().toISOString().slice(0,10);\n    await pptx.writeFile({fileName:`nvh-result-${stamp}${fnameSuffix||''}.pptx`});\n  } finally {\n    state.activeTab = originalTab;\n    loadTabState(getActiveTab());\n    renderTopTabs();\n    renderLabelsPage();\n    render();\n  }\n}\n\nfunction exportPptxAll(){\n  return exportTabsToPptx(state.tabs, '-all');\n}\nfunction exportPptxCurrent(){\n  const t = getActiveTab();\n  if(!t) return;\n  const safeName = String(t.name||'tab').replace(/[^A-Za-z0-9_\\-]+/g, '_');\n  return exportTabsToPptx([t], '-' + safeName);\n}\n\nfunction saveCurrentResult(){\n  saveActiveTabState();\n  const result = {\n    app: 'NVH Result Viewer',\n    version: 2,\n    savedAt: new Date().toISOString(),\n    nextModelId,\n    state: {\n      workbook: state.workbook,\n      axes: state.axes,\n      axisNames: state.axisNames,\n      pointCount: state.pointCount,\n      pointNames: state.pointNames,\n      models: state.models,\n      tabs: state.tabs,\n      activeTab: state.activeTab,\n      yMin: state.yMin, yMax: state.yMax, yMaj: state.yMaj,\n      xMin: state.xMin, xMax: state.xMax, xMaj: state.xMaj,\n      showGrid: state.showGrid,\n      showLegend: state.showLegend,\n      showPeaks: state.showPeaks,\n      showPeakLabels: state.showPeakLabels,\n      peakXMin: state.peakXMin,\n      peakXMax: state.peakXMax,\n      peakRanges: state.peakRanges,\n      xLabel: state.xLabel,\n      yLabel: state.yLabel,\n      chartW: state.chartW,\n      chartH: state.chartH\n    }\n  };\n  const json = JSON.stringify(result, null, 2);\n  downloadTextFile(`nvh-result-${new Date().toISOString().slice(0,10)}.json`, json, 'application/json');\n}\n\nasync function loadResultFile(file){\n  let result;\n  try {\n    result = JSON.parse(await file.text());\n  } catch(err) {\n    alert('Cannot read this JSON file.');\n    return;\n  }\n  if(!result || result.app !== 'NVH Result Viewer' || !result.state){\n    alert('This JSON file is not an NVH Viewer result.');\n    return;\n  }\n  Object.assign(state, result.state);\n  nextModelId = result.nextModelId || (Math.max(0, ...(state.models || []).map(m=>m.id || 0)) + 1);\n\n  // Backward compatibility: older saved JSON had one shared workbook/models set.\n  if(!state.tabs || !state.tabs.length){\n    state.tabs = [{id:'fr', name:'Frequency Response', xLabel:state.xLabel, yLabel:state.yLabel}];\n    state.activeTab = 'fr';\n  }\n  for(const tab of state.tabs) ensureTabState(tab);\n  const active = getActiveTab();\n  if(active && !active.workbook && state.workbook){\n    for(const key of TAB_STATE_KEYS) active[key] = clonePlain(state[key]);\n  }\n  loadTabState(getActiveTab());\n  renderTopTabs();\n  renderLabelsPage();\n  render();\n}\n\nfunction applyScaleToAllTabs(){\n  const scaleKeys = ['yMin','yMax','yMaj','xMin','xMax','xMaj'];\n  for(const key of scaleKeys){\n    const el = document.getElementById(key);\n    if(el) state[key] = parseFloat(el.value);\n  }\n  normalizePeakRanges();\n  saveActiveTabState();\n  for(const tab of state.tabs){\n    ensureTabState(tab);\n    for(const key of scaleKeys) tab[key] = state[key];\n    tab.peakRanges = clonePlain(state.peakRanges);\n    tab.peakXMin = state.peakXMin;\n    tab.peakXMax = state.peakXMax;\n  }\n  render();\n}\n\n// ───── Render ─────────────────────────────────────────\nfunction attachGroupResize(group){\n  const handle = document.createElement('div');\n  handle.className = 'grp-resize';\n  handle.title = 'Drag to resize group width';\n  group.appendChild(handle);\n  handle.addEventListener('pointerdown', (ev)=>{\n    if(ev.button !== 0) return;\n    ev.preventDefault(); ev.stopPropagation();\n    const startX = ev.clientX;\n    const startW = group.getBoundingClientRect().width;\n    document.body.classList.add('is-resizing');\n    handle.setPointerCapture(ev.pointerId);\n    const onMove = (e)=>{\n      const w = Math.max(80, Math.min(600, Math.round(startW + (e.clientX - startX))));\n      group.style.width = w + 'px';\n      group.style.maxWidth = 'none';\n      group.style.flex = '0 0 ' + w + 'px';\n    };\n    const onUp = ()=>{\n      handle.removeEventListener('pointermove', onMove);\n      handle.removeEventListener('pointerup', onUp);\n      handle.removeEventListener('pointercancel', onUp);\n      document.body.classList.remove('is-resizing');\n    };\n    handle.addEventListener('pointermove', onMove);\n    handle.addEventListener('pointerup', onUp);\n    handle.addEventListener('pointercancel', onUp);\n  });\n}\ndocument.querySelectorAll('.ribbon .ctrl-group').forEach(attachGroupResize);\n\nfunction render(){\n  const activeTab = getActiveTab();\n  const kind = (activeTab && activeTab.kind) || 'chart';\n  document.getElementById('app').dataset.kind = kind;\n\n  const host = document.getElementById('gridHost');\n  if(kind === 'modeshape'){\n    host.innerHTML = '';\n    ModeShapes.render(host, activeTab);\n    document.getElementById('legendHost').innerHTML = '';\n    renderStatus();\n    return;\n  }\n  host.classList.remove('ms-host');\n  // grid\n  host.innerHTML = '';\n  const wrap = document.createElement('div'); wrap.className='grid-wrap';\n  const grid = document.createElement('div'); grid.className='cgrid';\n  const axes = state.axes;\n  const points = Array.from({length: state.pointCount},(_,i)=>i+1);\n  const cellW = Math.max(180, Math.min(900, state.chartW || 320));\n  const cellH = Math.max(120, Math.min(650, state.chartH || 200));\n  state.chartW = cellW; state.chartH = cellH;\n  const gapPx = Math.max(0, +state.exportGap || 0);\n  grid.style.setProperty('--chart-gap', gapPx + 'px');\n  grid.style.gridTemplateColumns = `22px repeat(${points.length}, max-content)`;\n  // header\n  grid.appendChild(document.createElement('div'));\n  for(const p of points){\n    const ch = document.createElement('div'); ch.className='col-h'; ch.style.width=cellW+'px';\n    ch.textContent = state.pointNames[p] || `POINT ${p}`;\n    grid.appendChild(ch);\n  }\n  for(const ax of axes){\n    const rl = document.createElement('div'); rl.className='row-l'; rl.textContent = state.axisNames[ax] || ax;\n    grid.appendChild(rl);\n    for(const p of points){\n      const cell = document.createElement('div'); cell.className='cell';\n      cell.appendChild(drawChart(p, ax, cellW, cellH));\n      grid.appendChild(cell);\n    }\n  }\n  wrap.appendChild(grid);\n  host.appendChild(wrap);\n\n  // legend — one entry per model\n  const legHost = document.getElementById('legendHost');\n  legHost.innerHTML = '';\n  if(state.showLegend){\n    const leg = document.createElement('div'); leg.className='legend';\n    leg.innerHTML = '<b>Legend:<\u002Fb>';\n    for(const m of state.models){\n      const item = document.createElement('span'); item.className='lg-item' + (m.visible?'':' off');\n      item.innerHTML = `<span class=\"line22\" style=\"background:${m.color}\"><\u002Fspan>${m.name}`;\n      item.onclick = ()=>{ m.visible = !m.visible; render(); };\n      leg.appendChild(item);\n    }\n    leg.appendChild(Object.assign(document.createElement('span'),{className:'muted small',innerText:'  click to toggle'}));\n    legHost.appendChild(leg);\n  }\n\n  renderInspector();\n  renderStatus();\n}\n\nfunction renderInspector(){\n  // Sheet list\n  const sl = document.getElementById('sheetList');\n  if(state.workbook){\n    sl.innerHTML = state.workbook.names.map(n=>{\n      const r = state.workbook.sheets[n];\n      const cols = r && r[0] ? r[0].length : 0;\n      const rows = r ? r.length-1 : 0;\n      return `<div style=\"padding:2px 0\"><b>${n}<\u002Fb> <span class=\"muted\">· ${cols} cols × ${rows} rows<\u002Fspan><\u002Fdiv>`;\n    }).join('');\n  } else {\n    sl.innerHTML = '<span class=\"muted\">No sheets loaded.<\u002Fspan>';\n  }\n  // ds info\n  document.getElementById('dsInfo').textContent = state.workbook ? `${state.workbook.names.length} sheets · ${state.models.length} models` : 'no workbook';\n\n  // Models table — one row per model, with mapping table beneath\n  const tb = document.querySelector('#linesTable tbody');\n  tb.innerHTML = '';\n  document.getElementById('lineCount').textContent = state.models.length;\n\n  const sheets = state.workbook ? state.workbook.names : [];\n\n  for(const m of state.models){\n    const cols = (state.workbook && state.workbook.sheets[m.sheet]) ? (state.workbook.sheets[m.sheet][0]||[]) : [];\n    const colCount = cols.length;\n    const rowMax = (state.workbook && state.workbook.sheets[m.sheet]) ? state.workbook.sheets[m.sheet].length : 0;\n\n    // header row: vis · color · name · sheet · X col · row range · LW · del\n    const tr = document.createElement('tr');\n    tr.style.background = '#f7faff';\n    tr.innerHTML = `\n      <td><span class=\"check ${m.visible?'checked':''}\" data-act=\"vis\" data-mid=\"${m.id}\">${m.visible?'✓':''}<\u002Fspan><\u002Ftd>\n      <td><button type=\"button\" class=\"color-btn\" style=\"background:${m.color}\" data-act=\"color\" data-mid=\"${m.id}\" title=\"Pick model color\"><\u002Fbutton><\u002Ftd>\n      <td colspan=\"3\"><input type=\"text\" data-act=\"name\" data-mid=\"${m.id}\" value=\"${m.name}\" style=\"width:100%;font-weight:600\"><\u002Ftd>\n      <td colspan=\"2\"><select data-act=\"sheet\" data-mid=\"${m.id}\">${sheets.map(s=>`<option ${s===m.sheet?'selected':''}>${s}<\u002Foption>`).join('')}<\u002Fselect><\u002Ftd>\n      <td><span style=\"cursor:pointer;color:#c00000;font-weight:700\" data-act=\"del\" data-mid=\"${m.id}\">✕<\u002Fspan><\u002Ftd>`;\n    tb.appendChild(tr);\n\n    // X col + row range row\n    const trX = document.createElement('tr');\n    trX.innerHTML = `\n      <td colspan=\"2\" class=\"muted small\" style=\"text-align:right\">X col / Rows:<\u002Ftd>\n      <td><input type=\"text\" data-act=\"xCol\" data-mid=\"${m.id}\" value=\"${colLetter(m.xCol)}\" style=\"width:40px;text-align:center;font-family:Consolas,monospace\" title=\"Excel column letter for X (frequency)\"><\u002Ftd>\n      <td colspan=\"2\" class=\"muted small\" style=\"text-align:right\">rows&nbsp;<\u002Ftd>\n      <td><input type=\"number\" data-act=\"rowStart\" data-mid=\"${m.id}\" value=\"${m.rowStart}\" min=\"2\" max=\"${rowMax}\" style=\"width:55px\"><\u002Ftd>\n      <td><input type=\"number\" data-act=\"rowEnd\" data-mid=\"${m.id}\" value=\"${m.rowEnd}\" min=\"2\" max=\"${rowMax}\" style=\"width:55px\"><\u002Ftd>\n      <td><input type=\"number\" data-act=\"lw\" data-mid=\"${m.id}\" value=\"${m.lineWeight}\" min=\"0.5\" max=\"3\" step=\"0.1\" style=\"width:42px\" title=\"Line weight\"><\u002Ftd>`;\n    tb.appendChild(trX);\n\n    // Mapping grid: rows = axes, cols = points → which Y column letter\n    const trMap = document.createElement('tr');\n    const td = document.createElement('td');\n    td.colSpan = 8; td.style.padding = '4px 4px 8px 24px';\n    let mapHtml = `<div class=\"muted small\" style=\"margin-bottom:3px\">Y column per (axis · point) — Excel letters:<\u002Fdiv>\n      <table style=\"border-collapse:collapse\"><tr><th><\u002Fth>`;\n    for(let p=1; p<=state.pointCount; p++) mapHtml += `<th style=\"font-size:10px;color:#4a4a4a;padding:1px 4px\">P${p}<\u002Fth>`;\n    mapHtml += '<\u002Ftr>';\n    for(const ax of state.axes){\n      mapHtml += `<tr><th style=\"font-size:10px;color:#4a4a4a;padding:1px 4px\">${ax}<\u002Fth>`;\n      for(let p=1; p<=state.pointCount; p++){\n        const key = `P${p}_${ax}`;\n        const cur = m.mapping[key];\n        const val = (cur != null) ? colLetter(cur) : '';\n        mapHtml += `<td style=\"padding:1px\"><input type=\"text\" value=\"${val}\"\n          data-act=\"map\" data-mid=\"${m.id}\" data-key=\"${key}\"\n          style=\"width:34px;text-align:center;font-family:Consolas,monospace;font-size:11px;padding:2px 3px;border:1px solid #c8c8c8;border-radius:2px\" title=\"Y col letter, e.g. B, C, AA\"><\u002Ftd>`;\n      }\n      mapHtml += '<\u002Ftr>';\n    }\n    mapHtml += '<\u002Ftable>';\n    td.innerHTML = mapHtml;\n    trMap.appendChild(td);\n    tb.appendChild(trMap);\n  }\n\n  // axis checkboxes\n  const ab = document.getElementById('axBoxes');\n  ab.innerHTML = '';\n  for(const a of ['X','Y','Z']){\n    const lbl = document.createElement('label');\n    lbl.style.cssText = 'display:inline-flex;align-items:center;gap:4px;cursor:pointer';\n    const ck = document.createElement('span');\n    ck.className = 'check' + (state.axes.includes(a)?' checked':'');\n    ck.textContent = state.axes.includes(a)?'✓':'';\n    ck.onclick = ()=>{\n      const has = state.axes.includes(a);\n      const next = has ? state.axes.filter(x=>x!==a) : [...state.axes, a].sort();\n      if(next.length) state.axes = next;\n      render();\n    };\n    lbl.appendChild(ck); lbl.appendChild(document.createTextNode(a));\n    ab.appendChild(lbl);\n  }\n}\n\nfunction renderStatus(){\n  document.getElementById('status1').textContent = state.workbook ? 'Loaded' : 'Ready';\n  document.getElementById('status2').textContent = `X:${state.xMin}–${state.xMax} · Y:${state.yMin}–${state.yMax} · ${state.models.length} models · ${state.axes.length}×${state.pointCount} grid`;\n  const chartSizeInfo = document.getElementById('chartSizeInfo');\n  if(chartSizeInfo) chartSizeInfo.textContent = `Chart size: ${state.chartW || 320} × ${state.chartH || 200} px.`;\n}\n\n// ───── Event delegation for inspector ───────────────────\ndocument.addEventListener('change', e=>{\n  const t = e.target;\n  const act = t.dataset.act, mid = +t.dataset.mid;\n  if(!act || !mid) return;\n  const m = state.models.find(x=>x.id===mid); if(!m) return;\n  if(act==='name') m.name = t.value;\n  else if(act==='sheet'){\n    m.sheet = t.value;\n    const rows = state.workbook.sheets[t.value];\n    m.rowStart = 2; m.rowEnd = rows ? rows.length : 2;\n    m.xCol = 0;\n  }\n  else if(act==='xCol'){\n    const ci = colIndex(t.value);\n    if(ci>=0) m.xCol = ci;\n    t.value = colLetter(m.xCol);\n  }\n  else if(act==='rowStart') m.rowStart = Math.max(2, +t.value || 2);\n  else if(act==='rowEnd')   m.rowEnd   = Math.max(m.rowStart, +t.value || m.rowStart);\n  else if(act==='lw') m.lineWeight = parseFloat(t.value)||1;\n  else if(act==='map'){\n    const key = t.dataset.key;\n    const v = String(t.value||'').trim();\n    if(v === ''){ delete m.mapping[key]; }\n    else {\n      const ci = colIndex(v);\n      if(ci>=0) m.mapping[key] = ci;\n      t.value = (m.mapping[key]!=null) ? colLetter(m.mapping[key]) : '';\n    }\n  }\n  render();\n});\ndocument.addEventListener('click', e=>{\n  const t = e.target;\n  const act = t.dataset.act, mid = +t.dataset.mid;\n  if(!act || !mid) return;\n  const m = state.models.find(x=>x.id===mid); if(!m) return;\n  if(act==='vis'){ m.visible = !m.visible; render(); }\n  else if(act==='del'){ state.models = state.models.filter(x=>x.id!==mid); render(); }\n  else if(act==='color'){\n    openColorPopup(t, m.color, (newColor)=>{\n      m.color = newColor;\n      render();\n    });\n  }\n});\n\n// ───── Excel-style color picker ─────────────────────────\nconst EXCEL_THEME_COLORS = [\n  ['#FFFFFF','#000000','#EEECE1','#1F497D','#4F81BD','#C0504D','#9BBB59','#8064A2','#4BACC6','#F79646'],\n  ['#F2F2F2','#7F7F7F','#DDD9C3','#C6D9F0','#DBE5F1','#F2DCDB','#EBF1DD','#E4DFEC','#DAEEF3','#FDE9D9'],\n  ['#D8D8D8','#595959','#C4BD97','#8DB3E2','#B8CCE4','#E5B9B7','#D7E3BC','#CCC1D9','#B6DDE8','#FBD4B4'],\n  ['#BFBFBF','#3F3F3F','#948A54','#548DD4','#95B3D7','#D99694','#C3D69B','#B2A1C7','#92CDDC','#FAC08F'],\n  ['#A5A5A5','#262626','#494429','#17365D','#366092','#953734','#76923C','#5F497A','#31859B','#E36C09'],\n  ['#7F7F7F','#0C0C0C','#1D1B10','#0F243E','#244061','#632523','#4F6128','#3F3151','#205867','#974806'],\n];\nconst EXCEL_STANDARD_COLORS = ['#C00000','#FF0000','#FFC000','#FFFF00','#92D050','#00B050','#00B0F0','#0070C0','#002060','#7030A0'];\n\nfunction normalizeHex(v){\n  let s = String(v||'').trim();\n  if(!s) return null;\n  if(s[0] !== '#') s = '#' + s;\n  if(/^#[0-9A-Fa-f]{3}$/.test(s)){\n    s = '#' + s.slice(1).split('').map(c=>c+c).join('');\n  }\n  return /^#[0-9A-Fa-f]{6}$/.test(s) ? s.toUpperCase() : null;\n}\n\nlet _activeColorPopup = null;\nfunction closeColorPopup(){\n  if(_activeColorPopup){\n    _activeColorPopup.remove();\n    _activeColorPopup = null;\n    document.removeEventListener('mousedown', _outsideColorHandler, true);\n  }\n}\nfunction _outsideColorHandler(e){\n  if(_activeColorPopup && !_activeColorPopup.contains(e.target) && !e.target.classList.contains('color-btn')){\n    closeColorPopup();\n  }\n}\nfunction openColorPopup(anchorEl, currentColor, onPick){\n  closeColorPopup();\n  const cur = normalizeHex(currentColor) || '#000000';\n  const pop = document.createElement('div');\n  pop.className = 'color-popup';\n  const themeRows = EXCEL_THEME_COLORS.map(row=>{\n    return row.map(c=>`<div class=\"cp-sw${normalizeHex(c)===cur?' selected':''}\" data-c=\"${c}\" style=\"background:${c}\" title=\"${c}\"><\u002Fdiv>`).join('');\n  }).join('');\n  const stdRow = EXCEL_STANDARD_COLORS.map(c=>`<div class=\"cp-sw${normalizeHex(c)===cur?' selected':''}\" data-c=\"${c}\" style=\"background:${c}\" title=\"${c}\"><\u002Fdiv>`).join('');\n  pop.innerHTML = `\n    <div class=\"cp-h\">Theme Colors<\u002Fdiv>\n    <div class=\"cp-grid\">${themeRows}<\u002Fdiv>\n    <div class=\"cp-h\">Standard Colors<\u002Fdiv>\n    <div class=\"cp-grid\" style=\"grid-template-rows:16px\">${stdRow}<\u002Fdiv>\n    <div class=\"cp-h\">More Colors<\u002Fdiv>\n    <div class=\"cp-row\">\n      <input type=\"color\" class=\"cp-native\" value=\"${cur}\">\n      <input type=\"text\" class=\"cp-hex\" value=\"${cur}\" maxlength=\"7\" placeholder=\"#RRGGBB\">\n      <span class=\"cp-preview\" style=\"display:inline-block;width:22px;height:18px;border:1px solid #8c8c8c;background:${cur}\"><\u002Fspan>\n    <\u002Fdiv>\n    <div class=\"cp-actions\">\n      <button type=\"button\" class=\"btn cp-cancel\">Cancel<\u002Fbutton>\n      <button type=\"button\" class=\"btn primary cp-apply\">Apply<\u002Fbutton>\n    <\u002Fdiv>`;\n  document.body.appendChild(pop);\n  const r = anchorEl.getBoundingClientRect();\n  let left = r.left + window.scrollX;\n  let top = r.bottom + window.scrollY + 4;\n  pop.style.left = '0px'; pop.style.top = '0px';\n  const pw = pop.offsetWidth, ph = pop.offsetHeight;\n  if(left + pw > window.scrollX + document.documentElement.clientWidth - 8){\n    left = window.scrollX + document.documentElement.clientWidth - pw - 8;\n  }\n  if(top + ph > window.scrollY + document.documentElement.clientHeight - 8){\n    top = r.top + window.scrollY - ph - 4;\n  }\n  pop.style.left = Math.max(8, left) + 'px';\n  pop.style.top = Math.max(8, top) + 'px';\n  _activeColorPopup = pop;\n\n  let chosen = cur;\n  const hexIn = pop.querySelector('.cp-hex');\n  const native = pop.querySelector('.cp-native');\n  const preview = pop.querySelector('.cp-preview');\n  function setChosen(c, fromHexInput){\n    const n = normalizeHex(c);\n    if(!n) return;\n    chosen = n;\n    if(!fromHexInput) hexIn.value = n;\n    native.value = n;\n    preview.style.background = n;\n    pop.querySelectorAll('.cp-sw').forEach(s=>{\n      s.classList.toggle('selected', normalizeHex(s.dataset.c)===n);\n    });\n  }\n  pop.querySelectorAll('.cp-sw').forEach(s=>{\n    s.addEventListener('click', ()=>{\n      setChosen(s.dataset.c);\n      onPick(chosen);\n      closeColorPopup();\n    });\n  });\n  hexIn.addEventListener('input', ()=>{\n    const n = normalizeHex(hexIn.value);\n    if(n){ setChosen(n, true); }\n  });\n  native.addEventListener('input', ()=> setChosen(native.value));\n  pop.querySelector('.cp-apply').addEventListener('click', ()=>{\n    onPick(chosen);\n    closeColorPopup();\n  });\n  pop.querySelector('.cp-cancel').addEventListener('click', closeColorPopup);\n\n  setTimeout(()=>{\n    document.addEventListener('mousedown', _outsideColorHandler, true);\n  }, 0);\n}\n\n// ───── Toolbar/UI handlers ──────────────────────────────\ndocument.getElementById('saveBtn').onclick = saveCurrentResult;\ndocument.getElementById('exportPptxBtn').onclick = exportPptxAll;\ndocument.getElementById('exportCurrentBtn').onclick = exportPptxCurrent;\ndocument.getElementById('exportGap').addEventListener('change', e=>{\n  const v = Math.max(0, Math.min(200, +e.target.value || 0));\n  state.exportGap = v;\n  e.target.value = v;\n  render();\n});\ndocument.getElementById('applyScaleAllBtn').onclick = applyScaleToAllTabs;\nfunction _scanDataRange(){\n  let lo=Infinity, hi=-Infinity, xLo=Infinity, xHi=-Infinity;\n  for(const m of state.models){\n    if(!m.visible) continue;\n    for(let p=1; p<=state.pointCount; p++){\n      for(const ax of state.axes){\n        const d = getModelLine(m, p, ax);\n        for(const [x,y] of d){\n          if(y<lo)lo=y; if(y>hi)hi=y; if(x<xLo)xLo=x; if(x>xHi)xHi=x;\n        }\n      }\n    }\n  }\n  return {lo, hi, xLo, xHi};\n}\ndocument.getElementById('autoFitXBtn').onclick = ()=>{\n  const {xLo, xHi} = _scanDataRange();\n  if(!isFinite(xLo)) return;\n  state.xMin = Math.floor(xLo/100)*100;\n  state.xMax = Math.ceil(xHi/100)*100;\n  state.xMaj = Math.max(50, Math.round((state.xMax-state.xMin)/4/50)*50);\n  document.getElementById('xMin').value=state.xMin;\n  document.getElementById('xMax').value=state.xMax;\n  document.getElementById('xMaj').value=state.xMaj;\n  render();\n};\ndocument.getElementById('autoFitYBtn').onclick = ()=>{\n  const {lo, hi} = _scanDataRange();\n  if(!isFinite(lo)) return;\n  const pad=(hi-lo)*0.1;\n  state.yMin = Math.floor((lo-pad)/5)*5;\n  state.yMax = Math.ceil((hi+pad)/5)*5;\n  state.yMaj = Math.max(1, Math.ceil((state.yMax-state.yMin)/6/5)*5);\n  document.getElementById('yMin').value=state.yMin;\n  document.getElementById('yMax').value=state.yMax;\n  document.getElementById('yMaj').value=state.yMaj;\n  render();\n};\nfunction setInspector(open){\n  const app = document.getElementById('app');\n  app.classList.toggle('collapsed', !open);\n  app.style.gridTemplateColumns = '';\n}\nfunction _toggleInspector(){\n  const collapsed = document.getElementById('app').classList.contains('collapsed');\n  setInspector(collapsed);\n  const btn = document.getElementById('toggleInspTop');\n  if(btn){\n    const ico = btn.querySelector('.ico');\n    if(ico) ico.textContent = collapsed ? '◀' : '▶';\n    else btn.textContent = collapsed ? '◀' : '▶';\n  }\n}\ndocument.getElementById('toggleInsp').onclick = _toggleInspector;\ndocument.getElementById('toggleInspTop').onclick = _toggleInspector;\ndocument.getElementById('hideInsp').onclick = ()=>{ setInspector(false); const b=document.getElementById('toggleInspTop'); if(b){const i=b.querySelector('.ico'); if(i) i.textContent='◀'; else b.textContent='◀';} };\ndocument.getElementById('reopen').onclick   = ()=>{ setInspector(true); const b=document.getElementById('toggleInspTop'); if(b){const i=b.querySelector('.ico'); if(i) i.textContent='▶'; else b.textContent='▶';} };\n\ndocument.getElementById('fileIn').onchange = async (e)=>{\n  const file = e.target.files && e.target.files[0];\n  if(file) await loadFile(file);\n  e.target.value='';\n};\nconst drop = document.getElementById('drop');\ndrop.onclick = ()=> document.getElementById('fileIn').click();\n['dragover','dragenter'].forEach(ev=>drop.addEventListener(ev, e=>{e.preventDefault(); drop.classList.add('over');}));\n['dragleave','drop'].forEach(ev=>drop.addEventListener(ev, e=>{e.preventDefault(); drop.classList.remove('over');}));\ndrop.addEventListener('drop', async e=>{\n  const file = e.dataTransfer.files && e.dataTransfer.files[0];\n  if(file) await loadFile(file);\n});\n\n// scale inputs\n['yMin','yMax','yMaj','xMin','xMax','xMaj'].forEach(id=>{\n  document.getElementById(id).addEventListener('change', e=>{\n    state[id] = parseFloat(e.target.value);\n    render();\n  });\n});\ndocument.getElementById('addPeakRangeBtn').addEventListener('click', ()=>{\n  if(!Array.isArray(state.peakRanges)) state.peakRanges = [];\n  const last = state.peakRanges[state.peakRanges.length-1] || {min:0, max:state.xMax||2000};\n  state.peakRanges.push({min: last.max, max: (state.xMax||2000)});\n  normalizePeakRanges();\n  renderPeakRangesList();\n  render();\n});\ndocument.getElementById('pointsN').addEventListener('change', e=>{\n  state.pointCount = Math.max(1,Math.min(10, +e.target.value));\n  renderLabelsPage();\n  render();\n});\ndocument.getElementById('chartW').addEventListener('change', e=>{\n  state.chartW = Math.max(180, Math.min(900, +e.target.value || 320));\n  e.target.value = state.chartW;\n  render();\n});\ndocument.getElementById('chartH').addEventListener('change', e=>{\n  state.chartH = Math.max(120, Math.min(650, +e.target.value || 200));\n  e.target.value = state.chartH;\n  render();\n});\ndocument.getElementById('cbGrid').onclick = function(){state.showGrid=!state.showGrid; this.className='check'+(state.showGrid?' checked':''); this.textContent=state.showGrid?'✓':''; render();};\ndocument.getElementById('cbLeg').onclick = function(){state.showLegend=!state.showLegend; this.className='check'+(state.showLegend?' checked':''); this.textContent=state.showLegend?'✓':''; render();};\ndocument.getElementById('cbPeak').onclick = function(){state.showPeaks=!state.showPeaks; this.className='check'+(state.showPeaks?' checked':''); this.textContent=state.showPeaks?'✓':''; render();};\ndocument.getElementById('cbPeakLabel').onclick = function(){state.showPeakLabels=!state.showPeakLabels; this.className='check'+(state.showPeakLabels?' checked':''); this.textContent=state.showPeakLabels?'✓':''; render();};\n\ndocument.getElementById('addLineBtn').onclick = ()=>{\n  if(!state.workbook){ alert('Load a workbook first'); return; }\n  const sheet = state.workbook.names[0];\n  const rows = state.workbook.sheets[sheet];\n  const ci = state.models.length;\n  state.models.push({\n    id: nextModelId++, name: `model_${ci+1}`, color: COLORS[ci % COLORS.length],\n    visible:true, lineWeight:1, sheet,\n    xCol: 0, rowStart: 2, rowEnd: rows.length,\n    mapping: {},\n  });\n  render();\n};\n\n// tabs handled by renderTopTabs()\n\n// resizable inspector (grip drag)\nlet dragging = false;\ndocument.getElementById('grip').addEventListener('mousedown', e=>{\n  dragging = true;\n  e.preventDefault();\n  document.getElementById('app').style.userSelect = 'none';\n});\nwindow.addEventListener('mousemove', e=>{\n  if(!dragging) return;\n  const w = window.innerWidth - e.clientX;\n  document.getElementById('app').style.setProperty('--insp', Math.max(280, Math.min(700, w)) + 'px');\n});\nwindow.addEventListener('mouseup', ()=>{\n  dragging = false;\n  document.getElementById('app').style.userSelect = '';\n});\n\n// ───── Top tabs (dynamic, editable) ─────────────────────\nfunction startInlineTabRename(label, tab){\n  const input = document.createElement('input');\n  input.type = 'text';\n  input.className = 'tab-name-input';\n  input.value = tab.name;\n  label.replaceWith(input);\n  input.focus();\n  input.select();\n  const finish = (save=true)=>{\n    const value = input.value.trim();\n    if(save && value) tab.name = value;\n    renderTopTabs();\n  };\n  input.onkeydown = e=>{\n    if(e.key === 'Enter') finish(true);\n    else if(e.key === 'Escape') finish(false);\n  };\n  input.onblur = ()=> finish(true);\n  input.onclick = e=> e.stopPropagation();\n  input.ondblclick = e=> e.stopPropagation();\n}\n\nfunction renderTopTabs(){\n  const host = document.getElementById('topTabs');\n  host.innerHTML = '';\n  for(const tab of state.tabs){\n    const el = document.createElement('div');\n    el.className = 'tab editable' + (tab.id===state.activeTab ? ' active' : '');\n    el.dataset.tabid = tab.id;\n    const label = document.createElement('span');\n    label.textContent = tab.name;\n    label.title = 'Double-click to edit tab name';\n    label.ondblclick = (e)=>{\n      e.stopPropagation();\n      startInlineTabRename(label, tab);\n    };\n    el.appendChild(label);\n    if(state.tabs.length > 1){\n      const x = document.createElement('span'); x.className='tab-x'; x.textContent='×';\n      x.title = 'Remove tab';\n      x.onclick = (e)=>{\n        e.stopPropagation();\n        if(!confirm(`Remove tab \"${tab.name}\"?`)) return;\n        const wasActive = state.activeTab===tab.id;\n        state.tabs = state.tabs.filter(t=>t.id!==tab.id);\n        if(wasActive){\n          state.activeTab = state.tabs[0].id;\n          loadTabState(getActiveTab());\n        }\n        renderTopTabs();\n        renderLabelsPage();\n        render();\n      };\n      el.appendChild(x);\n    }\n    el.onclick = ()=> switchTopTab(tab.id);\n    host.appendChild(el);\n  }\n  // + add tab\n  const plus = document.createElement('div');\n  plus.className = 'tab';\n  plus.style.cssText = 'background:transparent;border-color:transparent;color:#1d4d80;font-weight:600';\n  plus.textContent = '＋';\n  plus.title = 'Add tab';\n  plus.onclick = addTopTab;\n  host.appendChild(plus);\n}\nfunction switchTopTab(id){\n  saveActiveTabState();\n  const tab = state.tabs.find(t=>t.id===id); if(!tab) return;\n  state.activeTab = id;\n  loadTabState(tab);\n  renderTopTabs();\n  renderLabelsPage();\n  render();\n}\nfunction addTopTab(){\n  saveActiveTabState();\n  const choice = prompt('Tab type? Enter \"chart\" or \"mode\" (mode shapes)', 'chart');\n  if(!choice) return;\n  const kind = /^mode/i.test(choice) ? 'modeshape' : 'chart';\n  const id = 't'+Date.now().toString(36);\n  const name = kind === 'modeshape' ? `Mode Shapes ${state.tabs.filter(t=>t.kind==='modeshape').length+1}` : `New Tab ${state.tabs.length + 1}`;\n  const newTab = {id, name, kind, ...makeDefaultTabState({xLabel:state.xLabel, yLabel:state.yLabel})};\n  state.tabs.push(newTab);\n  switchTopTab(id);\n}\n\n// ───── Labels page renderer ─────────────────────────────\nfunction renderLabelsPage(){\n  // axis names (X/Y/Z, even axes not currently shown can be edited)\n  const axBody = document.getElementById('axNamesBody');\n  axBody.innerHTML = '';\n  for(const a of ['X','Y','Z']){\n    const r = document.createElement('div'); r.className='row-2';\n    const lbl = document.createElement('label'); lbl.textContent = a + ' label';\n    const inp = document.createElement('input'); inp.type='text';\n    inp.value = state.axisNames[a] || a;\n    inp.oninput = ()=>{ state.axisNames[a] = inp.value || a; render(); };\n    r.appendChild(lbl); r.appendChild(inp);\n    axBody.appendChild(r);\n  }\n\n  // point names\n  const ptBody = document.getElementById('ptNamesBody');\n  ptBody.innerHTML = '';\n  for(let p=1; p<=state.pointCount; p++){\n    const r = document.createElement('div'); r.className='row-2';\n    const lbl = document.createElement('label'); lbl.textContent = `Point ${p}`;\n    const inp = document.createElement('input'); inp.type='text';\n    inp.value = state.pointNames[p] || `POINT ${p}`;\n    inp.oninput = ()=>{ state.pointNames[p] = inp.value || `POINT ${p}`; render(); };\n    r.appendChild(lbl); r.appendChild(inp);\n    ptBody.appendChild(r);\n  }\n}\n\n// inspector tab switching\ndocument.querySelectorAll('.insp-tab').forEach(t=>{\n  t.onclick = ()=>{\n    document.querySelectorAll('.insp-tab').forEach(x=>x.classList.remove('active'));\n    document.querySelectorAll('.insp-page').forEach(x=>x.classList.remove('active'));\n    t.classList.add('active');\n    document.querySelector(`[data-ipage=\"${t.dataset.itab}\"]`).classList.add('active');\n  };\n});\n\n// xLab/yLab now also persist into the active tab\ndocument.getElementById('xLab').addEventListener('input', e=>{\n  state.xLabel = e.target.value;\n  const at = state.tabs.find(t=>t.id===state.activeTab); if(at) at.xLabel = e.target.value;\n  render();\n});\ndocument.getElementById('yLab').addEventListener('input', e=>{\n  state.yLabel = e.target.value;\n  const at = state.tabs.find(t=>t.id===state.activeTab); if(at) at.yLabel = e.target.value;\n  render();\n});\n\n// init\nModeShapes.setOnChange(()=>{ saveActiveTabState(); render(); schedulePersist(); });\ninitializeTabState();\nloadPersistedState();\nrenderTopTabs();\nrenderLabelsPage();\nrender();\n\n// ───── localStorage persistence ─────\nconst PERSIST_KEY = 'nvh-demo-v3-state';\nlet _persistTimer = null;\nfunction schedulePersist(){\n  if(_persistTimer) clearTimeout(_persistTimer);\n  _persistTimer = setTimeout(persistNow, 300);\n}\nfunction persistNow(){\n  try{\n    saveActiveTabState();\n    // strip workbook (large, re-loadable); strip ModeShapes gifKey blobs (they live in IndexedDB)\n    const slim = {\n      activeTab: state.activeTab,\n      tabs: state.tabs.map(t=>{\n        const copy = clonePlain(t);\n        if(copy.workbook) copy.workbook = null;\n        return copy;\n      })\n    };\n    localStorage.setItem(PERSIST_KEY, JSON.stringify(slim));\n  }catch(e){ console.warn('persist failed', e); }\n}\nfunction loadPersistedState(){\n  try{\n    const raw = localStorage.getItem(PERSIST_KEY);\n    if(!raw) return;\n    const data = JSON.parse(raw);\n    if(!data.tabs || !data.tabs.length) return;\n    state.tabs = data.tabs;\n    state.activeTab = data.activeTab && state.tabs.find(t=>t.id===data.activeTab) ? data.activeTab : state.tabs[0].id;\n    for(const tab of state.tabs) ensureTabState(tab);\n    loadTabState(getActiveTab());\n  }catch(e){ console.warn('restore failed', e); }\n}\nwindow.addEventListener('beforeunload', persistNow);\n// Persist on any state-mutating UI change\n['click','change','input'].forEach(ev=>{\n  document.addEventListener(ev, ()=> schedulePersist(), true);\n});\n\n// global GIF drag-and-drop → mode shape import\nlet _msDropDepth = 0;\nlet _msDropOverlay = null;\nfunction ensureMsDropOverlay(){\n  if(_msDropOverlay) return _msDropOverlay;\n  _msDropOverlay = document.createElement('div');\n  _msDropOverlay.id = 'msDropOverlay';\n  _msDropOverlay.style.cssText = 'position:fixed;inset:0;background:rgba(43,108,176,0.15);border:3px dashed #2b6cb0;display:none;align-items:center;justify-content:center;z-index:9000;font:600 18px \"Meiryo UI\",sans-serif;color:#1a4f8c;pointer-events:none';\n  _msDropOverlay.textContent = '📁 Drop .gif files to import — auto-detect frequency from filename';\n  document.body.appendChild(_msDropOverlay);\n  return _msDropOverlay;\n}\nfunction hasGifFiles(dt){\n  if(!dt || !dt.types) return false;\n  if(![...dt.types].includes('Files')) return false;\n  // dataTransfer.items can sniff during dragover\n  if(dt.items && dt.items.length){\n    for(const it of dt.items) if(it.kind === 'file' && /gif/i.test(it.type||'')) return true;\n    // fallback: any file is candidate during drag (we filter at drop)\n    return true;\n  }\n  return true;\n}\nwindow.addEventListener('dragenter', e=>{\n  const at = getActiveTab();\n  if(!at || at.kind !== 'modeshape') return;\n  if(!hasGifFiles(e.dataTransfer)) return;\n  // skip if dropping into a cell — handled by ModeShapes\n  if(e.target.closest('.ms-cell.ms-empty, .ms-modal-overlay, .drop')) return;\n  e.preventDefault();\n  _msDropDepth++;\n  ensureMsDropOverlay().style.display = 'flex';\n});\nwindow.addEventListener('dragover', e=>{\n  const at = getActiveTab();\n  if(at && at.kind === 'modeshape' && hasGifFiles(e.dataTransfer)){\n    if(!e.target.closest('.drop')) e.preventDefault();\n  }\n});\nwindow.addEventListener('dragleave', e=>{\n  if(_msDropDepth > 0){\n    _msDropDepth--;\n    if(_msDropDepth === 0 && _msDropOverlay) _msDropOverlay.style.display = 'none';\n  }\n});\nwindow.addEventListener('drop', async e=>{\n  const at = getActiveTab();\n  if(!at || at.kind !== 'modeshape'){ return; }\n  // ignore drops handled by an empty cell\n  if(e.target.closest('.ms-cell.ms-empty, .ms-modal-overlay, .drop')) return;\n  e.preventDefault();\n  _msDropDepth = 0;\n  if(_msDropOverlay) _msDropOverlay.style.display = 'none';\n  const files = Array.from(e.dataTransfer.files||[]).filter(f=>/\\.gif$/i.test(f.name));\n  if(!files.length) return;\n  // Trigger import preview by simulating internal call\n  const ms = ModeShapes.ensureData(at);\n  // We re-use ModeShapes' import flow via a custom event-like path:\n  // create a fresh file input with these files won't work, so call internal helper via temporarily\n  // exposing showImportPreview through the global. Instead, dispatch by re-rendering & opening picker isn't ideal —\n  // the cleanest: ModeShapes exports a helper. Since it doesn't, fallback: place files into modes with auto-parse.\n  const parsed = files.map(f=>({file:f, info: ModeShapes.parseFilename(f.name)}));\n  // show a minimal confirmation via internal modal: re-create the same UI here would duplicate code,\n  // so we expose ModeShapes.importFiles if available; otherwise commit silently with parsed values.\n  if(typeof ModeShapes.importFiles === 'function'){\n    ModeShapes.importFiles(at, files);\n  } else {\n    // silent auto-import: only entries with detected freq + a model match\n    for(const {file, info} of parsed){\n      if(!Number.isFinite(info.freq)) continue;\n      const matched = ms.models.find(m => info.model && (m.name.toUpperCase().includes(info.model) || (m.id||'').toUpperCase()===info.model)) || ms.models[0];\n      if(!matched) continue;\n      let mode = ms.modes.find(m => Math.abs((m.freq??-9e9) - info.freq) < 0.01);\n      if(!mode){\n        const idx = (ms.modes.length ? Math.max(...ms.modes.map(m=>m.idx||0)) : 0) + 1;\n        mode = {idx, freq: info.freq, alias: info.alias||'', hidden:false};\n        ms.modes.push(mode);\n      }\n      const key = `${matched.id}-${mode.idx}`;\n      // we can't call internal putGif/deleteGif without exposing them — but ModeShapes does the right thing\n      // via empty-cell drop simulation: trigger via temporary cell drop\n      // Simpler: just call ModeShapes' internal via a fresh input — not possible. So we just rely on\n      // ModeShapes' showImportPreview. Expose by re-render once.\n    }\n    // Fallback: open picker pre-loaded — easiest: just open bulk import dialog and let user re-select.\n    alert(`Detected ${files.length} GIF(s). Click \"📁 Bulk import GIFs\" to commit (browser security prevents auto-attaching dropped files to the picker).`);\n  }\n});\n<\u002Fscript>\n\n\n<\u002Fbody><\u002Fhtml>"
  </script>
