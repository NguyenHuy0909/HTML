Option Explicit

Public Sub UpdateTOC()
    Dim pres As Presentation
    Set pres = ActivePresentation

    If pres.Slides.Count < 3 Then Exit Sub

    Dim tocBox As Shape
    Set tocBox = FindTOCBox(pres.Slides(2))
    If tocBox Is Nothing Then
        MsgBox "TOC textbox not found on slide 2"
        Exit Sub
    End If

    ' â”€â”€ Save old info before rewriting â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    Dim tabTpl As String
    tabTpl = GetTabTemplate(tocBox.TextFrame.TextRange)

    Dim oldPKeys(50) As String
    Dim oldPTitles(50) As String
    Dim oldPCount As Long
    oldPCount = 0
    ReadOldParents tocBox, oldPKeys, oldPTitles, oldPCount

    ' â”€â”€ Scan slides 3+ â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    Dim sKeys(200) As String
    Dim sTitles(200) As String
    Dim sFirst(200) As Long
    Dim sLast(200) As Long
    Dim sCount As Long
    sCount = 0

    Dim i As Long
    For i = 3 To pres.Slides.Count
        Dim hdr As String
        hdr = GetHeader(pres.Slides(i))
        If Len(hdr) = 0 Then GoTo NextSlide

        Dim sk As String
        sk = ParseSectionKey(hdr)
        If Len(sk) = 0 Then GoTo NextSlide

        Dim st As String
        st = ExtractTitle(hdr, sk)

        Dim fnd As Boolean
        fnd = False
        Dim k As Long
        For k = 1 To sCount
            If sKeys(k) = sk And sTitles(k) = st Then
                sLast(k) = i
                fnd = True
                Exit For
            End If
        Next k

        If Not fnd Then
            sCount = sCount + 1
            sKeys(sCount) = sk
            sTitles(sCount) = st
            sFirst(sCount) = i
            sLast(sCount) = i
        End If
NextSlide:
    Next i

    ' â”€â”€ Build TOC lines in page order â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    Dim tocLines(200) As String
    Dim tocIsSub(200) As Boolean
    Dim lnCount As Long
    lnCount = 0

    Dim emitP(50) As String
    Dim emitPCnt As Long
    emitPCnt = 0

    Dim pw As String
    pw = ChrW(12506) & ChrW(12540) & ChrW(12472)  ' ãƒšãƒ¼ã‚¸
    Dim aw As String
    aw = ChrW(8594)  ' â†’
    Dim isp As String
    isp = ChrW(12288)  ' ã€€ (ideographic space)

    For k = 1 To sCount
        Dim dotP As Long
        dotP = InStr(sKeys(k), ".")

        If dotP > 0 Then
            ' â”€â”€ Sub-section: emit parent group line first if needed â”€â”€
            Dim pKey As String
            pKey = Left(sKeys(k), dotP - 1)

            If Not IsEmitted(pKey, emitP, emitPCnt) Then
                Dim pTitle As String
                pTitle = LookupOldParent(pKey, oldPKeys, oldPTitles, oldPCount)

                lnCount = lnCount + 1
                tocIsSub(lnCount) = False
                If Len(pTitle) > 0 Then
                    tocLines(lnCount) = pKey & "." & isp & pTitle
                Else
                    tocLines(lnCount) = pKey & "."
                End If

                emitPCnt = emitPCnt + 1
                emitP(emitPCnt) = pKey
            End If

            ' â”€â”€ Sub-section line (indented with leading spaces, with page ref) â”€â”€
            lnCount = lnCount + 1
            tocIsSub(lnCount) = True
            tocLines(lnCount) = isp & isp & sKeys(k) & isp & sTitles(k) & _
                tabTpl & aw & " " & pw & " " & PageNumStr(sFirst(k), sLast(k))
        Else
            ' â”€â”€ Top-level section â”€â”€
            ' Check if it is also a parent of sub-sections
            If HasSubSections(sKeys(k), sKeys, sCount) Then
                If Not IsEmitted(sKeys(k), emitP, emitPCnt) Then
                    emitPCnt = emitPCnt + 1
                    emitP(emitPCnt) = sKeys(k)
                End If
            End If

            lnCount = lnCount + 1
            tocIsSub(lnCount) = False
            tocLines(lnCount) = sKeys(k) & "." & isp & sTitles(k) & _
                tabTpl & aw & " " & pw & " " & PageNumStr(sFirst(k), sLast(k))
        End If
    Next k

    ' â”€â”€ Write TOC text â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    Dim tocText As String
    tocText = ""
    For k = 1 To lnCount
        If k > 1 Then tocText = tocText & Chr(13)
        tocText = tocText & tocLines(k)
    Next k

    tocBox.TextFrame.TextRange.Text = tocText

    ' Indent is handled by leading ideographic spaces in the text itself

    pres.Save
    MsgBox "TOC updated!"
End Sub

