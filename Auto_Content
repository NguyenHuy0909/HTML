Private Function FindTOCBox(sld As Slide) As Shape
    Dim shp As Shape
    Dim pw As String
    pw = ChrW(12506) & ChrW(12540) & ChrW(12472)
    For Each shp In sld.Shapes
        If shp.Name = "TextBox 1" Then
            If shp.HasTextFrame Then
                Set FindTOCBox = shp
                Exit Function
            End If
        End If
    Next shp
    For Each shp In sld.Shapes
        If shp.HasTextFrame Then
            If InStr(shp.TextFrame.TextRange.Text, pw) > 0 Then
                Set FindTOCBox = shp
                Exit Function
            End If
        End If
    Next shp
End Function

Private Function GetHeader(sld As Slide) As String
    Dim shp As Shape
    For Each shp In sld.Shapes
        If shp.Name = "header" Then
            If shp.HasTextFrame Then
                GetHeader = Trim(shp.TextFrame.TextRange.Text)
                Exit Function
            End If
        End If
    Next shp
End Function

Private Function ParseSectionKey(s As String) As String
    Dim result As String
    result = ""
    Dim inSub As Boolean
    inSub = False
    Dim i As Long, startPos As Long
    startPos = 1
    Do While startPos <= Len(s)
        Dim cp As Long
        cp = AscW(Mid(s, startPos, 1))
        If cp = 32 Or cp = 9 Or cp = 12288 Then
            startPos = startPos + 1
        Else
            Exit Do
        End If
    Loop
    Dim c As String
    For i = startPos To Len(s)
        c = Mid(s, i, 1)
        If c >= "0" And c <= "9" Then
            result = result & c
        ElseIf c = "." Then
            If inSub Or Len(result) = 0 Then Exit For
            If i < Len(s) Then
                If Mid(s, i + 1, 1) >= "0" And Mid(s, i + 1, 1) <= "9" Then
                    result = result & "."
                    inSub = True
                Else
                    Exit For
                End If
            Else
                Exit For
            End If
        Else
            Exit For
        End If
    Next i
    ParseSectionKey = result
End Function

Private Function ExtractTitle(header As String, key As String) As String
    Dim pos As Long
    pos = Len(key) + 1
    Do While pos <= Len(header)
        Dim cp As Long
        cp = AscW(Mid(header, pos, 1))
        If cp = 46 Or cp = 32 Or cp = 12288 Or cp = 12290 Then
            pos = pos + 1
        Else
            Exit Do
        End If
    Loop
    Dim result As String
    result = Mid(header, pos)
    Do While Len(result) > 0
        Dim lc As Long
        lc = AscW(Right(result, 1))
        If lc = 13 Or lc = 10 Or lc = 11 Then
            result = Left(result, Len(result) - 1)
        Else
            Exit Do
        End If
    Loop
    ExtractTitle = result
End Function

Private Function PageNumStr(firstPage As Long, lastPage As Long) As String
    If lastPage > firstPage Then
        PageNumStr = CStr(firstPage) & ChrW(65374) & CStr(lastPage)
    Else
        PageNumStr = CStr(firstPage)
    End If
End Function

Private Function GetTabTemplate(tr As TextRange) As String
    Dim pw As String
    pw = ChrW(12506) & ChrW(12540) & ChrW(12472)
    Dim p As Long
    For p = 1 To tr.Paragraphs.Count
        Dim pt As String
        pt = tr.Paragraphs(p).Text
        If InStr(pt, pw) > 0 Then
            Dim arrowP As Long
            arrowP = InStr(pt, ChrW(8594))
            Dim tabS As Long
            tabS = InStr(pt, Chr(9))
            If tabS > 0 And arrowP > tabS Then
                GetTabTemplate = Mid(pt, tabS, arrowP - tabS)
                Exit Function
            End If
        End If
    Next p
    GetTabTemplate = Chr(9) & Chr(9) & Chr(9) & Chr(9) & Chr(9)
End Function

Private Sub ReadOldParents(tocBox As Shape, keys() As String, titles() As String, cnt As Long)
    Dim tr As TextRange
    Set tr = tocBox.TextFrame.TextRange
    Dim pw As String
    pw = ChrW(12506) & ChrW(12540) & ChrW(12472)
    Dim p As Long
    For p = 1 To tr.Paragraphs.Count
        Dim pt As String
        pt = tr.Paragraphs(p).Text
        If InStr(pt, pw) > 0 Then GoTo NextOld
        Dim key As String
        key = ParseSectionKey(pt)
        If Len(key) = 0 Then GoTo NextOld
        If InStr(key, ".") > 0 Then GoTo NextOld
        cnt = cnt + 1
        keys(cnt) = key
        titles(cnt) = ExtractTitle(pt, key)
NextOld:
    Next p
End Sub

Private Function LookupOldParent(pKey As String, keys() As String, titles() As String, cnt As Long) As String
    Dim i As Long
    For i = 1 To cnt
        If keys(i) = pKey Then
            LookupOldParent = titles(i)
            Exit Function
        End If
    Next i
    LookupOldParent = ""
End Function

Private Function IsEmitted(key As String, arr() As String, cnt As Long) As Boolean
    Dim i As Long
    For i = 1 To cnt
        If arr(i) = key Then
            IsEmitted = True
            Exit Function
        End If
    Next i
    IsEmitted = False
End Function

Private Function HasSubSections(key As String, sKeys() As String, sCount As Long) As Boolean
    Dim prefix As String
    prefix = key & "."
    Dim j As Long
    For j = 1 To sCount
        If Left(sKeys(j), Len(prefix)) = prefix Then
            HasSubSections = True
            Exit Function
        End If
    Next j
    HasSubSections = False
End Function

